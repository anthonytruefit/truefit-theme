{% doc %}
  @prompt
    a simple fully customizable text block. I want to be able to edit color, size, alignment of text.
{% enddoc %}
{% style %}
  #custom-text-{{ block.id }} {
    font-size: {{ block.settings.text_size }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }
{% endstyle %}

<div id="custom-text-{{ block.id }}" class="custom-text-block">
  {{ block.settings.text }}
</div>

{% schema %}
{
  "name": "Custom Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add your custom text here</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Text Size",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0A1A4F"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 24
    }
  ]
}
{% endschema %}