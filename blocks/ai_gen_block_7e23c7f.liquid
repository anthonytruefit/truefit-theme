{% doc %}
  @prompt
    I would like to add a basic image section. On mobile the size should be 600 x 770 and on desktop it should be 1639 x 2135. It should offer desktop/mobile width options as well as fully customizable color options for the background., The background color should match exactly the background color of the image but it is not.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    {% if block.settings.background_color != blank and block.settings.background_color != 'rgba(0,0,0,0)' %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
  }

  .ai-image-block-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-block-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-block-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1639 / 2135;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-block-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-block-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-image-block-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width_percent }}%;
    }

    .ai-image-block-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 600 / 770;
    }
  }
{% endstyle %}

<div
  class="ai-image-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-block-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      <picture>
        {% if block.settings.mobile_image %}
          <source
            media="(max-width: 749px)"
            srcset="{{ block.settings.mobile_image | image_url: width: 1200 }}"
          >
        {% endif %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-image-block-image-{{ ai_gen_id }}"
        >
      </picture>
    {% else %}
      <div class="ai-image-block-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-image-block-empty-state-{{ ai_gen_id }}">
          Add an image to get started
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Responsive image",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "paragraph",
      "content": "Recommended size: Desktop 1639 x 2135px, Mobile 600 x 770px"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_width_percent",
      "label": "Mobile width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    }
  ],
  "presets": [
    {
      "name": "Responsive image"
    }
  ]
}
{% endschema %}
