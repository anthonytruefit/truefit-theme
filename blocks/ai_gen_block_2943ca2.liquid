{% doc %}
  @prompt
    I would like to add a basic image section. On mobile the size should be 600 x 770 and on desktop it should be 1639 x 2135. The images should fill the entire width of the site.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-full-width-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-full-width-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin: 0;
    padding: 0;
    line-height: 0;
  }

  .ai-full-width-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-full-width-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-full-width-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-full-width-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-full-width-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 1639 / 2135;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-full-width-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 600 / 770;
    }
  }
{% endstyle %}

<div class="ai-full-width-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-full-width-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image_desktop != blank or block.settings.image_mobile != blank %}
      {% if block.settings.image_mobile != blank %}
        <img
          src="{{ block.settings.image_mobile | image_url: width: 600 }}"
          srcset="{{ block.settings.image_mobile | image_url: width: 600 }} 600w,
                  {{ block.settings.image_mobile | image_url: width: 1200 }} 1200w"
          sizes="100vw"
          alt="{{ block.settings.image_mobile.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_mobile.width }}"
          height="{{ block.settings.image_mobile.height }}"
          class="ai-full-width-image-mobile-{{ ai_gen_id }}"
          style="display: block;"
          media="(max-width: 749px)"
        >
      {% endif %}
      {% if block.settings.image_desktop != blank %}
        <img
          src="{{ block.settings.image_desktop | image_url: width: 1639 }}"
          srcset="{{ block.settings.image_desktop | image_url: width: 1639 }} 1639w,
                  {{ block.settings.image_desktop | image_url: width: 3278 }} 3278w"
          sizes="100vw"
          alt="{{ block.settings.image_desktop.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_desktop.width }}"
          height="{{ block.settings.image_desktop.height }}"
          class="ai-full-width-image-desktop-{{ ai_gen_id }}"
          style="{% if block.settings.image_mobile != blank %}display: none;{% else %}display: block;{% endif %}"
          media="(min-width: 750px)"
        >
      {% endif %}
    {% else %}
      <div class="ai-full-width-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-full-width-image-empty-state-{{ ai_gen_id }}">
          Add images for mobile and desktop
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  @media screen and (min-width: 750px) {
    .ai-full-width-image-mobile-{{ ai_gen_id }} {
      display: none !important;
    }
    .ai-full-width-image-desktop-{{ ai_gen_id }} {
      display: block !important;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-full-width-image-desktop-{{ ai_gen_id }} {
      {% if block.settings.image_mobile != blank %}
        display: none !important;
      {% endif %}
    }
    .ai-full-width-image-mobile-{{ ai_gen_id }} {
      display: block !important;
    }
  }
</style>

{% schema %}
{
  "name": "Full width image",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image",
      "info": "Recommended size: 1639 x 2135 px"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Recommended size: 600 x 770 px"
    }
  ],
  "presets": [
    {
      "name": "Full width image"
    }
  ]
}
{% endschema %}
