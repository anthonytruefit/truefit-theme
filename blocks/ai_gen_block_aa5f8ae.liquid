{% doc %}
  @prompt
    A featured product carousel with up to 8 product cards. It should be able to be swiped on mobile. Each product card should be customizable in the following ways: product selection, product title, product subtitle, price, add to cart button. I want the block to also have fully customizable header and subeader text., the product image needs to be added to the card when the product is selected. Right now there is no image, I would like to be able to customize the colors and size of all text including product title, subtitle, price, add to cart button, and headline. I should also have full customization of the button color, size, and shape.
{% enddoc %}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<style>
  .featured-carousel-{{ block.id }} {
    padding: 40px 0;
  }

  .featured-carousel-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .featured-carousel-header h2 {
    margin: 0 0 8px 0;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_color }};
    font-weight: {{ block.settings.header_font_weight }};
  }

  .featured-carousel-header p {
    margin: 0;
    font-size: {{ block.settings.subheader_font_size }}px;
    color: {{ block.settings.subheader_color }};
    opacity: 0.8;
  }

  .featured-carousel-wrapper {
    position: relative;
    overflow: hidden;
    margin: 0 auto;
    max-width: var(--page-width);
    padding: 0 1.5rem;
  }

  .featured-carousel-container {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .featured-carousel-container::-webkit-scrollbar {
    display: none;
  }

  .featured-product-card {
    flex: 0 0 280px;
    scroll-snap-align: start;
    background: rgb(var(--color-background));
    border-radius: {{ settings.card_corner_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .featured-product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .featured-product-image {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background: #f5f5f5;
    display: block;
  }

  .featured-product-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-product-image .placeholder-svg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .featured-product-content {
    padding: 20px;
  }

  .featured-product-title {
    margin: 0 0 4px 0;
    font-size: {{ block.settings.product_title_font_size }}px;
    font-weight: {{ block.settings.product_title_font_weight }};
    color: {{ block.settings.product_title_color }};
  }

  .featured-product-subtitle {
    margin: 0 0 12px 0;
    font-size: {{ block.settings.product_subtitle_font_size }}px;
    color: {{ block.settings.product_subtitle_color }};
    opacity: 0.7;
  }

  .featured-product-price {
    margin: 0 0 16px 0;
    font-size: {{ block.settings.product_price_font_size }}px;
    font-weight: {{ block.settings.product_price_font_weight }};
    color: {{ block.settings.product_price_color }};
  }

  .featured-product-button {
    width: 100%;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.2s ease;
    text-align: center;
    text-decoration: none;
    display: block;
  }

  .featured-product-button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .featured-product-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (min-width: 750px) {
    .featured-carousel-container {
      gap: 32px;
    }

    .featured-product-card {
      flex: 0 0 320px;
    }
  }

  @media screen and (max-width: 749px) {
    .featured-carousel-wrapper {
      padding: 0 1rem;
    }

    .featured-product-card {
      flex: 0 0 260px;
    }
  }
</style>

<div class="featured-carousel-{{ block.id }} color-{{ block.settings.color_scheme }} gradient">
  {% if block.settings.header_text != blank or block.settings.subheader_text != blank %}
    <div class="featured-carousel-header">
      {% if block.settings.header_text != blank %}
        <h2>{{ block.settings.header_text }}</h2>
      {% endif %}
      {% if block.settings.subheader_text != blank %}
        <p>{{ block.settings.subheader_text }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="featured-carousel-wrapper">
    <div class="featured-carousel-container">
      {% for i in (1..8) %}
        {% assign product_key = 'product_' | append: i %}
        {% assign title_key = 'product_' | append: i | append: '_title' %}
        {% assign subtitle_key = 'product_' | append: i | append: '_subtitle' %}
        {% assign price_key = 'product_' | append: i | append: '_price' %}
        {% assign button_key = 'product_' | append: i | append: '_button_text' %}
        
        {% assign product = block.settings[product_key] %}
        
        {% if product != blank %}
          <div class="featured-product-card">
            <a href="{{ product.url }}" class="featured-product-image">
              {% if product.featured_media %}
                {{
                  product.featured_media | image_url: width: 640 | image_tag:
                    loading: 'lazy',
                    width: product.featured_media.width,
                    height: product.featured_media.height,
                    alt: product.featured_media.alt | escape
                }}
              {% elsif product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 640 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="640"
                  height="640"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </a>
            
            <div class="featured-product-content">
              <h3 class="featured-product-title">
                {% if block.settings[title_key] != blank %}
                  {{ block.settings[title_key] }}
                {% else %}
                  {{ product.title }}
                {% endif %}
              </h3>
              
              {% if block.settings[subtitle_key] != blank %}
                <p class="featured-product-subtitle">{{ block.settings[subtitle_key] }}</p>
              {% endif %}
              
              <div class="featured-product-price">
                {% if block.settings[price_key] != blank %}
                  {{ block.settings[price_key] }}
                {% else %}
                  {{ product.price | money }}
                {% endif %}
              </div>
              
              <product-form>
                <form method="post" action="/cart/add" accept-charset="UTF-8" enctype="multipart/form-data">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button
                    type="submit"
                    name="add"
                    class="featured-product-button"
                    {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
                  >
                    {% if product.selected_or_first_available_variant.available %}
                      {% if block.settings[button_key] != blank %}
                        {{ block.settings[button_key] }}
                      {% else %}
                        Add to Cart
                      {% endif %}
                    {% else %}
                      Sold Out
                    {% endif %}
                  </button>
                </form>
              </product-form>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  if (!customElements.get('product-form')) {
    customElements.define('product-form', class ProductForm extends HTMLElement {
      constructor() {
        super();
        this.form = this.querySelector('form');
        this.form.addEventListener('submit', this.onSubmitHandler.bind(this));
      }

      onSubmitHandler(evt) {
        evt.preventDefault();
        const submitButton = this.querySelector('[type="submit"]');
        submitButton.setAttribute('disabled', true);
        submitButton.classList.add('loading');

        const formData = new FormData(this.form);
        formData.append('sections', 'cart-drawer,cart-icon-bubble');

        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          submitButton.removeAttribute('disabled');
          submitButton.classList.remove('loading');
          
          if (document.querySelector('cart-drawer')) {
            document.querySelector('cart-drawer').open();
          }
          
          fetch('/cart.js')
            .then(response => response.json())
            .then(cart => {
              document.querySelectorAll('.cart-count-bubble').forEach(bubble => {
                bubble.textContent = cart.item_count;
              });
            });
        })
        .catch(error => {
          console.error('Error:', error);
          submitButton.removeAttribute('disabled');
          submitButton.classList.remove('loading');
        });
      }
    });
  }
</script>

