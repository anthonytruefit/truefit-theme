{% doc %}
  @prompt
    Create a text box that is centered on the screen and can have an editable width and is left aligned inside the text box
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-box-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-text-box-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.box_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: left;
  }

  .ai-text-box-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
  }

  .ai-text-box-content-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-text-box-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-text-box-container-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.box_padding | times: 0.75 }}px;
    }

    .ai-text-box-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-box-container-{{ ai_gen_id }}">
    {% if block.settings.text_content != blank %}
      <div class="ai-text-box-content-{{ ai_gen_id }}">
        {{ block.settings.text_content }}
      </div>
    {% else %}
      <div class="ai-text-box-content-{{ ai_gen_id }}" style="color: #999; font-style: italic;">
        Add your text content in the block settings
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Centered text box",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Text",
      "default": "<p>Add your text content here. This text box is centered on the page with left-aligned text inside.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "range",
      "id": "box_padding",
      "label": "Box padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Centered text box"
    }
  ]
}
{% endschema %}
