{% doc %}
  @prompt
    A video block that appears to look like the video is playing directly on a phone background. I want to be able to choose the thumbnail for the video and it should have a play button right on top of it that plays the video embedded right there on the screen. I also want to write a short caption under the video., I should be able to upload the video from my library
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-phone-video-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-phone-video__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.phone_width }}px;
    margin: 0 auto;
  }

  .ai-phone-video__frame-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 200%;
    background: {{ block.settings.phone_color }};
    border-radius: {{ block.settings.phone_border_radius }}px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    overflow: hidden;
  }

  .ai-phone-video__notch-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40%;
    height: 30px;
    background: {{ block.settings.phone_color }};
    border-radius: 0 0 20px 20px;
    z-index: 3;
  }

  .ai-phone-video__screen-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.screen_padding }}px;
    left: {{ block.settings.screen_padding }}px;
    right: {{ block.settings.screen_padding }}px;
    bottom: {{ block.settings.screen_padding }}px;
    background: #000000;
    border-radius: {{ block.settings.screen_border_radius }}px;
    overflow: hidden;
  }

  .ai-phone-video__thumbnail-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .ai-phone-video__thumbnail-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-phone-video__thumbnail-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-phone-video__thumbnail-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-phone-video__play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.play_button_size }}px;
    height: {{ block.settings.play_button_size }}px;
    background-color: {{ block.settings.play_button_color }};
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
    z-index: 2;
  }

  .ai-phone-video__play-button-{{ ai_gen_id }}:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-phone-video__play-button-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-phone-video__play-icon-{{ ai_gen_id }} {
    width: 40%;
    height: 40%;
    margin-left: 10%;
  }

  .ai-phone-video__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }

  .ai-phone-video__video-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-phone-video__caption-{{ ai_gen_id }} {
    margin-top: 20px;
    text-align: {{ block.settings.caption_alignment }};
    color: {{ block.settings.caption_color }};
    font-size: {{ block.settings.caption_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-phone-video__container-{{ ai_gen_id }} {
      max-width: {{ block.settings.phone_width | times: 0.7 }}px;
    }

    .ai-phone-video__play-button-{{ ai_gen_id }} {
      width: {{ block.settings.play_button_size | times: 0.8 }}px;
      height: {{ block.settings.play_button_size | times: 0.8 }}px;
    }

    .ai-phone-video__caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<phone-video-{{ ai_gen_id }} class="ai-phone-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-phone-video__container-{{ ai_gen_id }}">
    <div class="ai-phone-video__frame-{{ ai_gen_id }}">
      {% if block.settings.show_notch %}
        <div class="ai-phone-video__notch-{{ ai_gen_id }}"></div>
      {% endif %}
      
      <div class="ai-phone-video__screen-{{ ai_gen_id }}">
        <div class="ai-phone-video__thumbnail-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_thumbnail %}
            <img
              src="{{ block.settings.video_thumbnail | image_url: width: 800 }}"
              alt="{{ block.settings.video_thumbnail.alt | escape }}"
              class="ai-phone-video__thumbnail-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.video_thumbnail.width }}"
              height="{{ block.settings.video_thumbnail.height }}"
            >
          {% else %}
            <div class="ai-phone-video__thumbnail-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <button
            class="ai-phone-video__play-button-{{ ai_gen_id }}"
            aria-label="Play video"
          >
            <svg
              class="ai-phone-video__play-icon-{{ ai_gen_id }}"
              viewBox="0 0 24 24"
              fill="{{ block.settings.play_button_icon_color }}"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
        </div>

        {% if block.settings.video_file != blank %}
          <video
            class="ai-phone-video__video-{{ ai_gen_id }}"
            {% if block.settings.enable_loop %}loop{% endif %}
            {% if block.settings.enable_mute %}muted{% endif %}
            playsinline
            controls
          >
            {% for source in block.settings.video_file.sources %}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {% endfor %}
          </video>
        {% endif %}
      </div>
    </div>

    {% if block.settings.caption != blank %}
      <div class="ai-phone-video__caption-{{ ai_gen_id }}">
        {{ block.settings.caption }}
      </div>
    {% endif %}
  </div>
</phone-video-{{ ai_gen_id }}>

<script>
  (function() {
    class PhoneVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.playButton = this.querySelector('.ai-phone-video__play-button-{{ ai_gen_id }}');
        this.video = this.querySelector('.ai-phone-video__video-{{ ai_gen_id }}');
        this.thumbnail = this.querySelector('.ai-phone-video__thumbnail-wrapper-{{ ai_gen_id }}');

        if (this.playButton && this.video) {
          this.setupEventListeners();
        }
      }

      setupEventListeners() {
        this.playButton.addEventListener('click', () => {
          this.playVideo();
        });

        this.video.addEventListener('ended', () => {
          this.resetVideo();
        });

        this.video.addEventListener('pause', () => {
          if (this.video.currentTime === this.video.duration) {
            this.resetVideo();
          }
        });
      }

      playVideo() {
        this.video.classList.add('active');
        this.playButton.classList.add('hidden');
        this.video.play();
      }

      resetVideo() {
        this.video.classList.remove('active');
        this.playButton.classList.remove('hidden');
        this.video.currentTime = 0;
      }
    }

    customElements.define('phone-video-{{ ai_gen_id }}', PhoneVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Phone video player",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "video_thumbnail",
      "label": "Video thumbnail"
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_mute",
      "label": "Mute video",
      "default": false
    },
    {
      "type": "header",
      "content": "Phone frame"
    },
    {
      "type": "range",
      "id": "phone_width",
      "label": "Phone width",
      "min": 200,
      "max": 500,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "color",
      "id": "phone_color",
      "label": "Phone color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "phone_border_radius",
      "label": "Phone border radius",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "show_notch",
      "label": "Show notch",
      "default": true
    },
    {
      "type": "range",
      "id": "screen_padding",
      "label": "Screen padding",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "screen_border_radius",
      "label": "Screen border radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Play button"
    },
    {
      "type": "range",
      "id": "play_button_size",
      "label": "Play button size",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "play_button_color",
      "label": "Play button color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "play_button_icon_color",
      "label": "Play button icon color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Caption"
    },
    {
      "type": "richtext",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "select",
      "id": "caption_alignment",
      "label": "Caption alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "caption_size",
      "label": "Caption size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Phone video player"
    }
  ]
}
{% endschema %}
