{% doc %}
  @prompt
    I want a responsive image block with two clickable hotspot areas and those areas do not need to be visible. The image should follow the responsive image guidelines, I would like to add a basic image section. On mobile the size should be 600 x 770 and on desktop it should be 1639 x 2135. It should offer desktop/mobile width options as well as fully customizable color options for the background., The background color should match exactly the background color of the image but it is not., I want a responsive image block with two clickable hotspot areas and those areas do not need to be visible. The image should follow the responsive image guidelines, I would like to add a basic image section. On mobile the size should be 600 x 770 and on desktop it should be 1639 x 2135. It should offer desktop/mobile width options as well as fully customizable color options for the background, It only needs to show the desktop image on desktop and mobile on mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hotspot-image-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-hotspot-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.mobile_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
  }

  .ai-hotspot-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-hotspot-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 600 / 770;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hotspot-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hotspot-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hotspot-image-desktop-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hotspot-image-mobile-{{ ai_gen_id }} {
    display: block;
  }

  .ai-hotspot-area-{{ ai_gen_id }} {
    position: absolute;
    cursor: pointer;
    z-index: 2;
  }

  .ai-hotspot-area-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  @media screen and (min-width: 750px) {
    .ai-hotspot-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }

    .ai-hotspot-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 1639 / 2135;
    }

    .ai-hotspot-image-desktop-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hotspot-image-mobile-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<hotspot-image-{{ ai_gen_id }}
  class="ai-hotspot-image-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hotspot-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image_desktop %}
      <img
        srcset="
          {%- if block.settings.image_desktop.width >= 375 -%}{{ block.settings.image_desktop | image_url: width: 375 }} 375w,{%- endif -%}
          {%- if block.settings.image_desktop.width >= 750 -%}{{ block.settings.image_desktop | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if block.settings.image_desktop.width >= 1100 -%}{{ block.settings.image_desktop | image_url: width: 1100 }} 1100w,{%- endif -%}
          {%- if block.settings.image_desktop.width >= 1500 -%}{{ block.settings.image_desktop | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if block.settings.image_desktop.width >= 1780 -%}{{ block.settings.image_desktop | image_url: width: 1780 }} 1780w,{%- endif -%}
          {%- if block.settings.image_desktop.width >= 2000 -%}{{ block.settings.image_desktop | image_url: width: 2000 }} 2000w,{%- endif -%}
          {%- if block.settings.image_desktop.width >= 3000 -%}{{ block.settings.image_desktop | image_url: width: 3000 }} 3000w,{%- endif -%}
          {%- if block.settings.image_desktop.width >= 3840 -%}{{ block.settings.image_desktop | image_url: width: 3840 }} 3840w{%- endif -%}
        "
        sizes="(min-width: 750px) {{ block.settings.desktop_width_percent }}vw, 100vw"
        src="{{ block.settings.image_desktop | image_url: width: 1639 }}"
        alt="{{ block.settings.image_desktop.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image_desktop.width }}"
        height="{{ block.settings.image_desktop.height }}"
        class="ai-hotspot-image-desktop-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.image_mobile %}
      <img
        srcset="
          {%- if block.settings.image_mobile.width >= 375 -%}{{ block.settings.image_mobile | image_url: width: 375 }} 375w,{%- endif -%}
          {%- if block.settings.image_mobile.width >= 600 -%}{{ block.settings.image_mobile | image_url: width: 600 }} 600w,{%- endif -%}
          {%- if block.settings.image_mobile.width >= 750 -%}{{ block.settings.image_mobile | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if block.settings.image_mobile.width >= 1100 -%}{{ block.settings.image_mobile | image_url: width: 1100 }} 1100w,{%- endif -%}
          {%- if block.settings.image_mobile.width >= 1200 -%}{{ block.settings.image_mobile | image_url: width: 1200 }} 1200w{%- endif -%}
        "
        sizes="(max-width: 749px) {{ block.settings.mobile_width_percent }}vw, 100vw"
        src="{{ block.settings.image_mobile | image_url: width: 600 }}"
        alt="{{ block.settings.image_mobile.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image_mobile.width }}"
        height="{{ block.settings.image_mobile.height }}"
        class="ai-hotspot-image-mobile-{{ ai_gen_id }}"
      >
    {% endif %}

    {% if block.settings.hotspot_1_enabled and block.settings.hotspot_1_url != blank %}
      <a
        href="{{ block.settings.hotspot_1_url }}"
        class="ai-hotspot-area-{{ ai_gen_id }}"
        style="
          top: {{ block.settings.hotspot_1_top }}%;
          left: {{ block.settings.hotspot_1_left }}%;
          width: {{ block.settings.hotspot_1_width }}%;
          height: {{ block.settings.hotspot_1_height }}%;
        "
        aria-label="{{ block.settings.hotspot_1_label }}"
      ></a>
    {% endif %}

    {% if block.settings.hotspot_2_enabled and block.settings.hotspot_2_url != blank %}
      <a
        href="{{ block.settings.hotspot_2_url }}"
        class="ai-hotspot-area-{{ ai_gen_id }}"
        style="
          top: {{ block.settings.hotspot_2_top }}%;
          left: {{ block.settings.hotspot_2_left }}%;
          width: {{ block.settings.hotspot_2_width }}%;
          height: {{ block.settings.hotspot_2_height }}%;
        "
        aria-label="{{ block.settings.hotspot_2_label }}"
      ></a>
    {% endif %}
  </div>
</hotspot-image-{{ ai_gen_id }}>

<script>
  (function() {
    class HotspotImage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('hotspot-image-{{ ai_gen_id }}', HotspotImage{{ ai_gen_id }});
  })();
</script>

