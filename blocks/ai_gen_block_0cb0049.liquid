{% doc %}
  @prompt
    A simple hero banner block that I can upload different images for on desktop vs mobile. I should be able to adjust the size for both as well., I want to be able to edit the width as well as height for each image., I don't want the size adjustments to crop the image, I want it to responsively re-size it but maintain the full imahge.
{% enddoc %}
{% comment %}
  Responsive Hero Banner Block
  Supports different images and sizes for desktop and mobile
  With width and height controls for each
  Images scale to fit without cropping
{% endcomment %}

{%- style -%}
  #hero-banner-{{ block.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #hero-banner-{{ block.id }} .hero-banner__image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #hero-banner-{{ block.id }} .hero-banner__image {
    display: block;
    object-fit: contain;
    width: 100%;
    height: 100%;
  }

  /* Desktop styles */
  @media screen and (min-width: 750px) {
    #hero-banner-{{ block.id }} .hero-banner__image-wrapper {
      width: {{ block.settings.desktop_width }}%;
      max-width: 100%;
      height: {{ block.settings.desktop_height }}px;
    }

    #hero-banner-{{ block.id }} .hero-banner__mobile {
      display: none;
    }

    #hero-banner-{{ block.id }} .hero-banner__desktop {
      display: block;
    }
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    #hero-banner-{{ block.id }} .hero-banner__image-wrapper {
      width: {{ block.settings.mobile_width }}%;
      max-width: 100%;
      height: {{ block.settings.mobile_height }}px;
    }

    #hero-banner-{{ block.id }} .hero-banner__desktop {
      display: none;
    }

    #hero-banner-{{ block.id }} .hero-banner__mobile {
      display: block;
    }
  }
{%- endstyle -%}

<div id="hero-banner-{{ block.id }}" class="hero-banner" {{ block.shopify_attributes }}>
  <div class="hero-banner__image-wrapper">
    {%- if block.settings.desktop_image != blank -%}
      {{ block.settings.desktop_image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'hero-banner__image hero-banner__desktop', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840', alt: block.settings.desktop_image.alt }}
    {%- else -%}
      <div class="hero-banner__desktop hero-banner__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}

    {%- if block.settings.mobile_image != blank -%}
      {{ block.settings.mobile_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'hero-banner__image hero-banner__mobile', widths: '375, 550, 750, 1000', alt: block.settings.mobile_image.alt }}
    {%- elsif block.settings.desktop_image != blank -%}
      {{ block.settings.desktop_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'hero-banner__image hero-banner__mobile', widths: '375, 550, 750, 1000', alt: block.settings.desktop_image.alt }}
    {%- else -%}
      <div class="hero-banner__mobile hero-banner__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Responsive Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image",
      "info": "Image will scale to fit without cropping"
    },
    {
      "type": "range",
      "id": "desktop_width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Desktop Width",
      "default": 100
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Desktop Height",
      "default": 600
    },
    {
      "type": "header",
      "content": "Mobile Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image",
      "info": "Image will scale to fit without cropping. If not set, desktop image will be used."
    },
    {
      "type": "range",
      "id": "mobile_width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Mobile Width",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Mobile Height",
      "default": 500
    }
  ],
  "presets": [
    {
      "name": "Responsive Hero Banner"
    }
  ]
}
{% endschema %}