{% doc %}
  @prompt
    I would like to add a basic image section. On mobile the size should be 600 x 546 and on desktop it should be 1639 x 1493. The images should fill the entire width of the site.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-full-width-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-full-width-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin: 0;
    padding: 0;
    line-height: 0;
  }

  .ai-full-width-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-full-width-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-full-width-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-full-width-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-full-width-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 1639 / 1493;
    }

    .ai-full-width-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 1639 / 1493;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-full-width-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: 600 / 546;
    }

    .ai-full-width-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 600 / 546;
    }
  }
{% endstyle %}

<div class="ai-full-width-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-full-width-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 1639 }}"
        srcset="{{ block.settings.image | image_url: width: 600 }} 600w,
                {{ block.settings.image | image_url: width: 1200 }} 1200w,
                {{ block.settings.image | image_url: width: 1639 }} 1639w"
        sizes="100vw"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
      >
    {% else %}
      <div class="ai-full-width-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-full-width-image-empty-state-{{ ai_gen_id }}">
          Add an image to get started
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Full width image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Full width image"
    }
  ],
  "tag": null
}
{% endschema %}
