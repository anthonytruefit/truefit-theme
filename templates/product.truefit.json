    "894e738c-d102-4245-8b24-f42264ccfba5": {
      "type": "amino-image-multirow",
      "blocks": {
        "template--15510886875181__894e738c-d102-4245-8b24-f42264ccfba5-167805591942128572-0": {
          "type": "row",
          "disabled": true,
