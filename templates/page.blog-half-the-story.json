_text_box":false,"desktop_content_position":"middle-center","desktop_column_width":12,"desktop_column_start":1,"desktop_content_max_width":300,"desktop_content_alignment":"center","color_scheme":"","customize_colors":false,"text_color":"","button_background_color":"","button_text_color":"","container_background_color":"","mobile_text_color":"","mobile_button_background_color":"","mobile_button_text_color":"","mobile_container_background_color":""}},"rich_text_ztUGnY":{"type":"rich-text","blocks":{"text_mRqCFz":{"type":"text","settings":{"text":"<p><strong>Protein Is Only Half the Story: Why Fiber Decides What Your Body Actually Uses<\/strong><\/p>"}},"text_WKXhac":{"type":"text","disabled":true,"settings":{"text":"<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.<\/p>"}},"button_WNWizi":{"type":"button","disabled":true,"settings":{"button_label":"Button label","button_link":"","button_style_secondary":false,"button_label_2":"","button_link_2":"","button_style_secondary_2":false}}},"block_order":["text_mRqCFz","text_WKXhac","button_WNWizi"],"name":"t:sections.rich-text.presets.name","settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":20,"padding_bottom":20}},"1780495005d505bb65":{"type":"_blocks","blocks":{"ai_gen_block_a26d1da_CR7p3L":{"type":"ai_gen_block_a26d1da","settings":{"text_content":"<p>Most people treat protein like the finish line. Hit the gram count, check the box, move on. But what your body absorbs is not the same as what you consumed, and that gap is where most protein shakes quietly fall short.<\/p><p>The missing variable is fiber.<br\/><br\/><em><strong>Why Speed Hurts Absorption<\/strong><\/em><\/p><p>When protein digests too quickly, amino acids hit the bloodstream in a rush. The body can only use so many at once, and the rest gets oxidized for energy or excreted rather than directed toward muscle repair. Research published in the <em>Journal of the International Society of Sports Nutrition<\/em> found that slower protein digestion rates support more sustained amino acid availability, which is associated with improved net protein utilization over time [1].<\/p><p>Fiber is one of the most effective tools for slowing that process. Soluble fiber forms a gel in the digestive tract that delays gastric emptying, which extends the window your body has to absorb amino acids steadily instead of all at once [2].<\/p>","desktop_width_percent":40,"box_padding":16,"vertical_padding":0,"background_color":"#ffffff","text_color":"#000000","font_size":14,"line_height":1.6,"border_radius":8},"blocks":{}}},"block_order":["ai_gen_block_a26d1da_CR7p3L"],"settings":{}},"1780499764e29092c3":{"type":"_blocks","blocks":{"ai_gen_block_0929f29_dnBNzF":{"type":"ai_gen_block_0929f29","settings":{"image":"shopify:\/\/shop_images\/TrueFit_004.jpg","image_max_width":400,"image_aspect_ratio":"16\/9","image_fit":"cover","image_position_x":40,"image_position_y":50,"image_border_radius":0,"caption":"<p><em>TrueFit offers 4-5g of fiber per scoop to help maximize protein absorption.<\/em><\/p>","caption_font_size":12,"caption_color":"#000000","text_alignment":"center","button_text":"Save 30% Today","button_link":"shopify:\/\/products\/truefit-vanilla","button_font_size":12,"button_font_weight":"400","button_padding_vertical":12,"button_padding_horizontal":24,"button_border_radius":16,"button_border_width":0,"button_bg_color":"#5b3b42","button_text_color":"#f0f0eb","button_border_color":"#5b3b42","button_bg_color_hover":"#000000","button_text_color_hover":"#ffffff","button_border_color_hover":"#000000","alignment":"center","spacing":12,"desktop_width_percent":100},"blocks":{}}},"block_order":["ai_gen_block_0929f29_dnBNzF"],"settings":{}},"blocks_GnLN4b":{"type":"_blocks","settings":{}},"blocks_qQ9EDE":{"type":"_blocks","blocks":{"ai_gen_block_a26d1da_bYLt8t":{"type":"ai_gen_block_a26d1da","settings":{"text_content":"<p><em><strong>The Gut Health Connection<\/strong><\/em><\/p><p>Fiber does more than slow things down. It feeds the gut microbiome, which plays a direct role in how efficiently the body processes protein. Fermentable fibers are broken down by gut bacteria into short chain fatty acids, which support intestinal barrier function and create the conditions for better nutrient uptake [3].<\/p><p>The problem is that most Americans are running a fiber deficit. The average adult consumes about 14 grams per day, well below the 25 to 38 grams recommended by the American Heart Association [4]. That gap shows up in digestion, satiety, and how much of your protein actually gets put to work.<\/p>","desktop_width_percent":40,"box_padding":24,"vertical_padding":0,"background_color":"#ffffff","text_color":"#000000","font_size":14,"line_height":1.6,"border_radius":8},"blocks":{}}},"block_order":["ai_gen_block_a26d1da_bYLt8t"],"settings":{}},"blocks_GenXGm":{"type":"_blocks","blocks":{"ai_gen_block_0929f29_ErY4Ui":{"type":"ai_gen_block_0929f29","settings":{"image":"shopify:\/\/shop_images\/TrueFit_007.jpg","image_max_width":400,"image_aspect_ratio":"16\/9","image_fit":"cover","image_position_x":40,"image_position_y":50,"image_border_radius":0,"caption":"<p><em>TrueFit contain 1 billion CFU probiotics to improve gut health and promote healthy gut microbiome.<\/em><\/p>","caption_font_size":12,"caption_color":"#000000","text_alignment":"center","button_text":"Save 30% Today","button_link":"shopify:\/\/products\/truefit-vanilla","button_font_size":12,"button_font_weight":"400","button_padding_vertical":12,"button_padding_horizontal":24,"button_border_radius":8,"button_border_width":1,"button_bg_color":"#5b3b42","button_text_color":"#f0f0eb","button_border_color":"#5b3b42","button_bg_color_hover":"#000000","button_text_color_hover":"#ffffff","button_border_color_hover":"#000000","alignment":"center","spacing":12,"desktop_width_percent":100},"blocks":{}}},"block_order":["ai_gen_block_0929f29_ErY4Ui"],"settings":{}},"blocks_wDjRHD":{"type":"_blocks","blocks":{"ai_gen_block_a26d1da_7piDGq":{"type":"ai_gen_block_a26d1da","settings":{"text_content":"<p><em><strong>Satiety Without the Calorie Cost<\/strong><\/em><\/p><p>Fiber and protein together also signal fullness more effectively than protein alone. Studies in <em>Nutrients<\/em> have shown that combining the two improves satiety hormone response and reduces subsequent calorie intake [5]. That matters whether you are building muscle, cutting, or just trying to stop snacking an hour after a shake.<\/p><p><em><strong>The TrueFit Equation<\/strong><\/em><\/p><p>TrueFit was built around this exact principle. Every scoop delivers 25 grams of grass fed protein and 5 grams of fiber, plus probiotics to reinforce the gut environment that makes absorption possible. Protein builds the muscle. Fiber makes sure your body can use it.<\/p><p>That is the half of the story most shakes leave out.<\/p>","desktop_width_percent":40,"box_padding":24,"vertical_padding":0,"background_color":"#ffffff","text_color":"#000000","font_size":14,"line_height":1.6,"border_radius":8},"blocks":{}}},"block_order":["ai_gen_block_a26d1da_7piDGq"],"settings":{}},"blocks_NkCnbK":{"type":"_blocks","blocks":{"ai_gen_block_5eabd5d_x77w4x":{"type":"ai_gen_block_5eabd5d","settings":{"image":"shopify:\/\/shop_images\/ChatGPT_Image_Jun_2_2026_05_36_33_PM.png","aspect_ratio":"16\/9","desktop_width_percent":50,"border_radius":0,"show_overlay":true,"overlay_color":"#000000","overlay_opacity":0.3,"show_content":true,"heading":"","heading_size":48,"heading_color":"#ffffff","text":"","text_size":16,"text_color":"#ffffff","text_alignment":"center","button_label":"Shop now","button_link":"","button_text_size":16,"button_color":"#ffdd00","button_hover_color":"#ffc700","button_text_color":"#000000","button_border_radius":40},"blocks":{}}},"block_order":["ai_gen_block_5eabd5d_x77w4x"],"disabled":true,"settings":{}},"blocks_Mw7fG8":