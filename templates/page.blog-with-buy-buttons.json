16,"vertical_padding":0,"background_color":"#ffffff","text_color":"#000000","font_size":14,"line_height":1.6,"border_radius":8},"blocks":{}}},"block_order":["ai_gen_block_a26d1da_CR7p3L"],"settings":{}},"1780499764e29092c3":{"type":"_blocks","blocks":{"ai_gen_block_0929f29_dnBNzF":{"type":"ai_gen_block_0929f29","settings":{"image":"shopify:\/\/shop_images\/TrueFit_004.jpg","image_max_width":400,"image_aspect_ratio":"16\/9","image_fit":"cover","image_position_x":40,"image_position_y":50,"image_border_radius":0,"caption":"<p><em>TrueFit offers <\/em><em><strong>25g <\/strong><\/em><em>of protein on just <\/em><em><strong>150 calories.<\/strong><\/em><\/p>","caption_font_size":12,"caption_color":"#000000","text_alignment":"center","button_text":"Save 30% Today","button_link":"shopify:\/\/products\/truefit-vanilla","button_font_size":12,"button_font_weight":"400","button_padding_vertical":12,"button_padding_horizontal":24,"button_border_radius":16,"button_border_width":0,"button_bg_color":"#5b3b42","button_text_color":"#f0f0eb","button_border_color":"#5b3b42","button_bg_color_hover":"#000000","button_text_color_hover":"#ffffff","button_border_color_hover":"#000000","alignment":"center","spacing":8,"desktop_width_percent":100},"blocks":{}}},"block_order":["ai_gen_block_0929f29_dnBNzF"],"settings":{}},"blocks_GnLN4b":{"type":"_blocks","settings":{}},"blocks_qQ9EDE":{"type":"_blocks","blocks":{"ai_gen_block_a26d1da_bYLt8t":{"type":"ai_gen_block_a26d1da","settings":{"text_content":"<p><em><strong>The Ratio Most Shakes Don't Want You to Notice<\/strong><\/em><\/p><p>Walk down any supplement aisle and you'll find shakes delivering 10–20 grams of protein for 300+ calories per serving. That's not proteinmaxxing, that's caloriemaxxing in disguise. Once you factor in added sugars, oils, and filler carbs, the protein you're actually getting per calorie is significantly less than the label implies.<\/p><p>TrueFit was built around a different equation: <strong>25 grams of grass-fed protein for just 150 calories.<\/strong> Scoop for scoop, that ratio outperforms most of the category. For anyone tracking macros, building lean mass, or staying in a deficit while still hitting protein targets, the math compounds fast. Three servings a day = 75g of protein for 450 calories, versus 30–60g for nearly twice the calories from a legacy shake.<\/p>","desktop_width_percent":40,"box_padding":24,"vertical_padding":0,"background_color":"#ffffff","text_color":"#000000","font_size":14,"line_height":1.6,"border_radius":8},"blocks":{}}},"block_order":["ai_gen_block_a26d1da_bYLt8t"],"settings":{}},"blocks_GenXGm":{"type":"_blocks","blocks":{"ai_gen_block_0929f29_ErY4Ui":{"type":"ai_gen_block_0929f29","settings":{"image":"shopify:\/\/shop_images\/TrueFit_007.jpg","image_max_width":400,"image_aspect_ratio":"16\/9","image_fit":"cover","image_position_x":40,"image_position_y":50,"image_border_radius":0,"caption":"<p><em>TrueFit offers a unique blend of <\/em><em><strong>protein + fiber <\/strong><\/em><em>to maximize absorption.<\/em><\/p>","caption_font_size":12,"caption_color":"#000000","text_alignment":"center","button_text":"Save 30% Today","button_link":"shopify:\/\/products\/truefit-vanilla","button_font_size":12,"button_font_weight":"400","button_padding_vertical":12,"button_padding_horizontal":24,"button_border_radius":8,"button_border_width":1,"button_bg_color":"#5b3b42","button_text_color":"#f0f0eb","button_border_color":"#5b3b42","button_bg_color_hover":"#000000","button_text_color_hover":"#ffffff","button_border_color_hover":"#000000","alignment":"center","spacing":8,"desktop_width_percent":100},"blocks":{}}},"block_order":["ai_gen_block_0929f29_ErY4Ui"],"settings":{}},"blocks_wDjRHD":{"type":"_blocks","blocks":{"ai_gen_block_a26d1da_7piDGq":{"type":"ai_gen_block_a26d1da","settings":{"text_content":"<p><em><strong>The Part Nobody Mentions: Fiber<\/strong><\/em><\/p><p>Here's where TrueFit pulls even further ahead, and it has nothing to do with marketing copy.<\/p><p>The average American consumes only about 14 grams of fiber per day, roughly half of what's recommended [2]. The American Heart Association and Academy of Nutrition and Dietetics recommend 25–38 grams daily, depending on age and sex [3]. That gap matters for more than digestion. Dietary fiber influences nutrient absorption through fermentation, bulking, viscosity, gel formation, and water-holding capacity and prebiotic fiber supports gut microbes that regulate how the body processes what you eat [4].<\/p><p><strong>In other words: protein doesn't just need to be consumed. It needs to be absorbed. And absorption is a function of gut health.<\/strong><\/p><p>That's why TrueFit includes 5g of prebiotic fiber and 1 billion CFU probiotics in every scoop. Fermentable fibers are broken down by gut microbiota to produce short-chain fatty acids, which support intestinal barrier function and microbial balance [5], the conditions that make protein worth taking in the first place. The fiber feeds the microbes. The probiotics reinforce the population. Together, they create the gut environment where 25g of protein actually does the work of 25g of protein.<\/p><p><em><strong>The Bottom Line<\/strong><\/em><\/p><p>Proteinmaxxing without absorption is just expensive guesswork. A higher protein-to-calorie ratio means you hit your targets without overshooting. A built-in fiber and probiotic system means your body can actually use what you put in it.<\/p><p><strong>That's not a marketing claim. That's how digestion works.<\/strong><\/p>","desktop_width_percent":40,"box_padding":24,"vertical_padding":0,"background_color":"#ffffff","text_color":"#000000","font_size":14,"line_height":1.6,"border_radius":8},"blocks":{}}},"block_order":["ai_gen_block_a26d1da_7piDGq"],"settings":{}},"blocks_Mw7fG8":{"type":"_blocks","settings":{}},"blocks_Hwtjj4":{"type":"_blocks","settings":{}},"blocks_J6LmJT":{"type":"_blocks","blocks":{"ai_gen_block_5eabd5d_HyrFDH":{"type":"ai_gen_block_5eabd5d