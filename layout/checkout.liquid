<!doctype html>
<html lang="{{ locale }}" dir="{{ direction }}" class="{{ checkout_html_classes }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0, user-scalable=0"
    >
    <meta name="referrer" content="origin">

    <title>{{ page_title }}</title>

    {%- liquid
      render 'vite-tag' with 'main.css'
      render 'vite-tag' with 'main.js'
    -%}
    {{ content_for_header }}

    {{ checkout_stylesheets }}
    {{ checkout_scripts }}

    <script type="application/javascript" async src="https://sdk.postscript.io/integrations/sdk-min.js"></script>
    {% render 'shogun-head' %}
  </head>
  <body>
    {{ skip_to_content_link }}

    <header class="banner" data-header role="banner">
      <div class="wrap">
        {{ content_for_logo }}
      </div>
    </header>

    {{ order_summary_toggle }}
    <div class="content" data-content>
      <div class="wrap">
        <div class="main">
          <header class="main__header" role="banner">
            {{ content_for_logo }}
            {{ breadcrumb }}
            {{ alternative_payment_methods }}
          </header>
          <main class="main__content" role="main">
            {{ content_for_layout }}
          </main>
          <footer class="main__footer" role="contentinfo">
            {{ content_for_footer }}
          </footer>
        </div>
        <aside class="sidebar" role="complementary">
          <div class="sidebar__header">
            {{ content_for_logo }}
          </div>
          <div class="sidebar__content">
            {{ content_for_order_summary }}
          </div>
        </aside>
      </div>
    </div>

    <script data-cfasync="false">
      window.ju_num = '62B9C7B8-BB36-4202-80E0-91F4CAE0FA21';
      window.asset_host = '//cdn.justuno.com/';
      (function (i, s, o, g, r, a, m) {
        i[r] =
          i[r] ||
          function () {
            (i[r].q = i[r].q || []).push(arguments);
          };
        (a = s.createElement(o)), (m = s.getElementsByTagName(o)[0]);
        a.async = 1;
        a.src = g;
        m.parentNode.insertBefore(a, m);
      })(window, document, 'script', asset_host + 'vck.js', 'juapp');
    </script>

    {% comment %} Redirect AminoLean-only carts to AminoLean cart template {% endcomment %}
    {%- liquid
      assign aminolean_only = true
      for item in checkout.line_items
        unless item.product.template contains 'amino' or item.title contains 'AminoLean' or item.title contains 'Alix'
          assign aminolean_only = false
          break
        endunless
      endfor
    -%}
    {% if aminolean_only %}
      <script>
        var rspLinks = document.querySelectorAll('a[href="https://rspnutrition.com/"]');
        for (var i = 0; i < rspLinks.length; i++) {
          var rspLink = rspLinks[i];
          rspLink.href = 'https://rspnutrition.com{{ settings.aminolean_homepage_link }}';
        }
        var cartLinks = document.querySelectorAll('a[href="https://rspnutrition.com/cart"]');
        for (var i = 0; i < cartLinks.length; i++) {
          var cartLink = cartLinks[i];
          cartLink.href = 'https://rspnutrition.com/cart?view=aminolean';
        }
      </script>
    {% endif %}

    {{ tracking_code }}
  </body>
</html>
