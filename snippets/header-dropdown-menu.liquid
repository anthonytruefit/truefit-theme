{% comment %}
  Renders a standard dropdown style menu for the header.

  Usage:
  {% render 'header-dropdown-menu' %}

  Accepts:
  - menu: {Object} Link list
  - position: {String} 'left' or 'right' (optional)
  - shop_menu {Object} Block from 'header' section of type 'shop_menu_desktop' (optional)
  - shop_menu_class {String} Class for shop menu (optional)
  - shop_menu_content {String} HTML content for shop menu items (optional)
{% endcomment %}
{%- liquid
  if menu == blank
    assign menu = section.settings.menu
  endif
-%}

<nav class="header__inline-menu{% if position != blank %} header__inline-menu--{{ position }}{% endif %}">
  <ul class="list-menu list-menu--inline" role="list">
    {%- if shop_menu != blank and shop_menu_content != blank -%}
      <li {{ shop_menu.shopify_attributes }}>
        <header-menu
          {% if section.settings.desktop_open_menu_hover %}
            data-open-on-hover="true"
          {% endif %}
        >
          <details id="Details-HeaderMenu-ShopFeatured">
            <summary class="header__menu-item list-menu__item link focus-inset" id="HeaderMenu-ShopFeatured">
              <span>{{ shop_menu.settings.title }}</span>
              {% render 'dawn-icon-caret' %}
            </summary>
            <ul
              id="HeaderMenu-MenuList-Shop"
              {% comment %} class="header__submenu list-menu shop-featured-menu list-menu--disclosure motion-reduce global-settings-popup" {% endcomment %}
              class="header__submenu {{ shop_menu_class }} list-menu list-menu--disclosure list-menu--disclosure-large color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
              role="list"
              tabindex="-1"
            >
              {%- if shop_menu.settings.shop_all_link_title != blank and shop_menu.settings.shop_all_link != blank -%}
                <li class="shop-cards-menu__text-item">
                  <a
                    href="{{ shop_menu.settings.shop_all_link }}"
                    class="shop-featured-menu__item list-menu__item link link--text focus-inset caption"
                  >
                    {{- shop_menu.settings.shop_all_link_title -}}
                  </a>
                </li>
              {%- endif -%}

              {{ shop_menu_content }}
            </ul>
          </details>
        </header-menu>
      </li>
    {%- endif -%}
    {%- for link in menu.links -%}
      <li>
        {%- if link.links != blank -%}
          <header-menu>
            <details id="Details-HeaderMenu-{{ forloop.index }}">
              <summary
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item list-menu__item link focus-inset"
              >
                <span
                  {%- if link.child_active %}
                    class="header__active-menu-item"
                  {% endif %}
                >
                  {{- link.title | escape -}}
                </span>
                {% render 'icon-caret' %}
              </summary>
              <ul
                id="HeaderMenu-MenuList-{{ forloop.index }}"
                class="header__submenu list-menu list-menu--disclosure color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                role="list"
                tabindex="-1"
              >
                {%- for childlink in link.links -%}
                  <li>
                    {%- if childlink.links == blank -%}
                      <a
                        id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                        href="{{ childlink.url }}"
                        class="header__menu-item list-menu__item link link--text focus-inset{% if childlink.current %} list-menu__item--active{% endif %}"
                        {% if childlink.current %}
                          aria-current="page"
                        {% endif %}
                      >
                        {{ childlink.title | escape }}
                      </a>
                    {%- else -%}
                      <details id="Details-HeaderSubMenu-{{ link.handle }}-{{ childlink.handle }}">
                        <summary
                          id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                          class="header__menu-item link link--text list-menu__item focus-inset"
                        >
                          <span>{{ childlink.title | escape }}</span>
                          {% render 'icon-caret' %}
                        </summary>
                        <ul
                          id="HeaderMenu-SubMenuList-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                          class="header__submenu list-menu motion-reduce"
                        >
                          {%- for grandchildlink in childlink.links -%}
                            <li>
                              <a
                                id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                href="{{ grandchildlink.url }}"
                                class="header__menu-item list-menu__item link link--text focus-inset{% if grandchildlink.current %} list-menu__item--active{% endif %}"
                                {% if grandchildlink.current %}
                                  aria-current="page"
                                {% endif %}
                              >
                                {{ grandchildlink.title | escape }}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </details>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            </details>
          </header-menu>
        {%- else -%}
          <a
            id="HeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="header__menu-item list-menu__item link link--text focus-inset"
            {% if link.current %}
              aria-current="page"
            {% endif %}
          >
            <span
              {%- if link.current %}
                class="header__active-menu-item"
              {% endif %}
            >
              {{- link.title | escape -}}
            </span>
          </a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>
