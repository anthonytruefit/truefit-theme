{% comment %}
  Premium mobile menu drawer (the single theme-wide menu design).
  Reuses Dawn's <header-drawer> / <details> open-close + focus mechanism;
  only the inner content is the new clean design, driven by header blocks:
  - drawer_button (x2)         -> the two quick-action buttons
  - drawer_nav_row             -> text nav rows (expandable via a menu, or direct link)
  - drawer_featured_product    -> small product-on-white featured items
  Logo is locked navy. Falls back gracefully when blocks are absent.
{% endcomment %}
<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {% render 'dawn-icon-hamburger' %}
        {% render 'amino-icon-close' %}
      </span>
    </summary>
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce" tabindex="-1">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container tfdrawer">

          {%- comment -%} 1. Top bar: logo + close {%- endcomment -%}
          <div class="tfdrawer__topbar">
            <a href="{{ root_url | default: routes.root_url }}" class="tfdrawer__logo-link" aria-label="{{ shop.name | escape }} home">
              {%- render 'rsp-logo', class: 'tfdrawer__logo' -%}
            </a>
            <button type="button" class="tfdrawer__close" aria-label="{{ 'accessibility.close' | t }}" onclick="this.closest('details').open=false">
              {% render 'amino-icon-close' %}
            </button>
          </div>

          {%- comment -%} 2. Quick-action buttons {%- endcomment -%}
          {%- assign tf_buttons = section.blocks | where: 'type', 'drawer_button' -%}
          {%- if tf_buttons.size > 0 -%}
            <div class="tfdrawer__buttons">
              {%- for b in tf_buttons limit: 2 -%}
                <a href="{{ b.settings.link | default: '#' }}" class="tfdrawer__btn tfdrawer__btn--{{ b.settings.style | default: 'filled' }}" {{ b.shopify_attributes }}>
                  {{ b.settings.label | default: 'Shop' }}
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} 3. Text nav rows {%- endcomment -%}
          {%- assign tf_rows = section.blocks | where: 'type', 'drawer_nav_row' -%}
          {%- if tf_rows.size > 0 -%}
            <nav class="tfdrawer__nav" aria-label="{{ 'sections.header.menu' | t }}">
              {%- for row in tf_rows -%}
                {%- if row.settings.mode == 'expandable' and row.settings.menu != blank and row.settings.menu.links.size > 0 -%}
                  <details class="tfdrawer__row tfdrawer__row--expandable" {{ row.shopify_attributes }}>
                    <summary class="tfdrawer__rowlabel">
                      <span>{{ row.settings.label }}</span>
                      <svg class="tfdrawer__chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8l4 4 4-4"/></svg>
                    </summary>
                    <ul class="tfdrawer__sublist list-unstyled">
                      {%- for link in row.settings.menu.links -%}
                        <li><a href="{{ link.url }}" class="tfdrawer__sublink{% if link.current %} tfdrawer__sublink--active{% endif %}">{{ link.title }}</a></li>
                      {%- endfor -%}
                    </ul>
                  </details>
                {%- else -%}
                  <a href="{{ row.settings.link | default: '#' }}" class="tfdrawer__row tfdrawer__row--direct tfdrawer__rowlabel" {{ row.shopify_attributes }}>
                    <span>{{ row.settings.label }}</span>
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </nav>
          {%- endif -%}

          {%- comment -%} 4. Featured products (small product-on-white) {%- endcomment -%}
          {%- assign tf_featured = section.blocks | where: 'type', 'drawer_featured_product' -%}
          {%- if tf_featured.size > 0 -%}
            <div class="tfdrawer__featured">
              <p class="tfdrawer__eyebrow">{{ section.settings.featured_label | default: 'FEATURED' }}</p>
              <ul class="tfdrawer__featured-list list-unstyled">
                {%- for f in tf_featured limit: 3 -%}
                  {%- assign fp = f.settings.product -%}
                  {%- assign fimg = f.settings.image | default: fp.featured_image -%}
                  <li class="tfdrawer__feat" {{ f.shopify_attributes }}>
                    <a href="{{ fp.url | default: '#' }}" class="tfdrawer__feat-link">
                      <span class="tfdrawer__feat-thumb">
                        {%- if fimg != blank -%}
                          <img src="{{ fimg | image_url: width: 160 }}" alt="{{ fp.title | default: f.settings.title | escape }}" width="72" height="72" loading="lazy">
                        {%- else -%}
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {%- endif -%}
                      </span>
                      <span class="tfdrawer__feat-body">
                        <span class="tfdrawer__feat-name">{{ f.settings.title | default: fp.title | default: 'Featured product' }}</span>
                        {%- if f.settings.description != blank -%}
                          <span class="tfdrawer__feat-desc">{{ f.settings.description }}</span>
                        {%- endif -%}
                      </span>
                      {%- if f.settings.badge != blank -%}
                        <span class="tfdrawer__feat-badge">{{ f.settings.badge }}</span>
                      {%- endif -%}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          {%- comment -%} 5. Bottom utility: account + social {%- endcomment -%}
          <div class="tfdrawer__utility">
            {%- if shop.customer_accounts_enabled -%}
              <div class="tfdrawer__account">
                {%- if customer -%}
                  <a href="{{ routes.account_url }}" class="tfdrawer__util-link">{{ 'customer.account_fallback' | t }}</a>
                {%- else -%}
                  <a href="{{ routes.account_login_url }}" class="tfdrawer__util-link">{{ 'customer.log_in' | t }}</a>
                  <span class="tfdrawer__util-sep" aria-hidden="true">/</span>
                  <a href="{{ routes.account_register_url }}" class="tfdrawer__util-link">{{ 'customer.register' | t }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
            <ul class="list list-social list-unstyled tfdrawer__social" role="list">
              {%- if settings.social_instagram_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_instagram_link }}" class="list-social__link link">{%- render 'icon-instagram' -%}<span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_tiktok_link }}" class="list-social__link link">{%- render 'icon-tiktok' -%}<span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_facebook_link }}" class="list-social__link link">{%- render 'icon-facebook' -%}<span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_youtube_link }}" class="list-social__link link">{%- render 'icon-youtube' -%}<span class="visually-hidden">{{ 'general.social.links.youtube' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_twitter_link }}" class="list-social__link link">{%- render 'icon-twitter' -%}<span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_pinterest_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_pinterest_link }}" class="list-social__link link">{%- render 'icon-pinterest' -%}<span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span></a></li>
              {%- endif -%}
            </ul>
          </div>

        </div>
      </div>
    </div>
  </details>
</header-drawer>
