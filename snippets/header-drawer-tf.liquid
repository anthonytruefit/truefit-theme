{% comment %}
  Premium mobile menu drawer (the single theme-wide menu design).
  Reuses Dawn's <header-drawer> / <details> open-close + focus mechanism;
  only the inner content is the new clean design, driven by header blocks:
  - drawer_button (x2)         -> the two quick-action buttons
  - drawer_nav_row             -> text nav rows (expandable via a menu, or direct link)
  - drawer_featured_product    -> small product-on-white featured items
  Logo is locked navy. Falls back gracefully when blocks are absent.
{% endcomment %}
<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {% render 'dawn-icon-hamburger' %}
        {% render 'amino-icon-close' %}
      </span>
    </summary>
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce" tabindex="-1">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container tfdrawer">

          {%- comment -%} 1. Top bar: logo + close {%- endcomment -%}
          <div class="tfdrawer__topbar">
            <a href="{{ root_url | default: routes.root_url }}" class="tfdrawer__logo-link" aria-label="{{ shop.name | escape }} home">
              {%- render 'rsp-logo', class: 'tfdrawer__logo' -%}
            </a>
            <button type="button" class="tfdrawer__close" aria-label="{{ 'accessibility.close' | t }}" onclick="this.closest('details').open=false">
              {% render 'amino-icon-close' %}
            </button>
          </div>

          {%- comment -%} 2-4. Shared menu body: buttons + nav rows + featured (also used by the desktop Shop menu) {%- endcomment -%}
          {%- render 'header-menu-tf-body', section: section -%}

          {%- comment -%} 5. Bottom utility: account + social {%- endcomment -%}
          <div class="tfdrawer__utility">
            {%- if shop.customer_accounts_enabled -%}
              <div class="tfdrawer__account">
                {%- if customer -%}
                  <a href="{{ routes.account_url }}" class="tfdrawer__util-link">{{ 'customer.account_fallback' | t }}</a>
                {%- else -%}
                  <a href="{{ routes.account_login_url }}" class="tfdrawer__util-link">{{ 'customer.log_in' | t }}</a>
                  <span class="tfdrawer__util-sep" aria-hidden="true">/</span>
                  <a href="{{ routes.account_register_url }}" class="tfdrawer__util-link">{{ 'customer.register.title' | t }}</a>
                {%- endif -%}
              </div>
            {%- endif -%}
            <ul class="list list-social list-unstyled tfdrawer__social" role="list">
              {%- if settings.social_instagram_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_instagram_link }}" class="list-social__link link">{%- render 'icon-instagram' -%}<span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_tiktok_link }}" class="list-social__link link">{%- render 'icon-tiktok' -%}<span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_facebook_link }}" class="list-social__link link">{%- render 'icon-facebook' -%}<span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_youtube_link }}" class="list-social__link link">{%- render 'icon-youtube' -%}<span class="visually-hidden">{{ 'general.social.links.youtube' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_twitter_link }}" class="list-social__link link">{%- render 'icon-twitter' -%}<span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span></a></li>
              {%- endif -%}
              {%- if settings.social_pinterest_link != blank -%}
                <li class="list-social__item"><a href="{{ settings.social_pinterest_link }}" class="list-social__link link">{%- render 'icon-pinterest' -%}<span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span></a></li>
              {%- endif -%}
            </ul>
          </div>

        </div>
      </div>
    </div>
  </details>
</header-drawer>
