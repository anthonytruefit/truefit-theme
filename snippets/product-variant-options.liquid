{% comment %}
  Renders product variant options

  Accepts:
  - product: {Object} product object.
  - option: {Object} current product_option object.
  - block: {Object} block object.
  - icon_dictionary: {Object} Icon dictionary metaobject (optional)


  Usage:
  {% render 'product-variant-options',
    product: product,
    option: option,
    block: block
  %}
{% endcomment %}
{%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'

  assign product_form_id = 'product-form-' | append: section.id
  assign option_name = option.name | downcase
-%}

{%- for value in option.values -%}
  {%- liquid
    assign option_disabled = true
    assign option_icon_file = false
    assign option_value = value | downcase
    for icon_block in icon_blocks
      assign icon_option_name = icon_block.settings.option_name | downcase
      assign icon_option_value = icon_block.settings.option_value | downcase
      if option_name == icon_option_name and option_value == icon_option_value
        assign option_icon_file = icon_block.settings.icon | image_url: width: 48
        break
      endif
    endfor
    if icon_dictionary != blank and option_icon_file == false
      assign option_icon_handle = option_name | append: '-' | append: option_value | handleize | replace: '-', '_'
      assign option_icon_file = icon_dictionary[option_icon_handle].value | image_url: width: 48
    endif

    for option1_name in variants_option1_arr
      case option.position
        when 1
          if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 2
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
        when 3
          if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
            assign option_disabled = false
          endif
      endcase
    endfor
  -%}

  {%- if picker_type == 'button' -%}
    <input
      type="radio"
      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      name="{{ option.name }}"
      value="{{ value | escape }}"
      form="{{ product_form_id }}"
      {% if option.selected_value == value %}
        checked
      {% endif %}
      class="tw-peer{% if option_disabled %} disabled{% endif %}"
    >
    <label
      for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
      {% if option_icon_file != blank %}
        style="--icon-mask:url({{ option_icon_file }});"
      {% endif %}
    >
      <span class="option-icon"></span>
      <span>
        {{- value -}}
      </span>
      <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
    </label>
  {%- elsif picker_type == 'dropdown' -%}
    <option
      value="{{ value | escape }}"
      {% if option.selected_value == value %}
        selected="selected"
      {% endif %}
    >
      {% if option_disabled -%}
        {{- 'products.product.value_unavailable' | t: option_value: value -}}
      {%- else -%}
        {{- value -}}
      {%- endif %}
    </option>
  {%- endif -%}
{%- endfor -%}
