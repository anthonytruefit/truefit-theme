{% comment %}
  TrueFit collection product card — mirrors the homepage best-seller card.
  Pulls everything from the product; the description, flavor line, subscribe
  price, and badge are manual product metafields (custom namespace) and each
  line hides when its metafield is empty. The image and title link to the
  product's PDP; the button is a quick add-to-cart (adds the product's first
  available variant via the theme's <product-form>).

  Accepts:
  - card_product: {Object} the product
  - lazy_load: {Boolean} lazy-load the image
  - view_label: {String} add-to-cart button label (default "Add to Cart")
{% endcomment %}
{%- liquid
  assign p = card_product
  assign card_title = p.metafields.custom.card_title.value | default: p.title
  assign desc = p.metafields.custom.card_description.value
  assign flavor = p.metafields.custom.card_flavor_line.value
  assign sub = p.metafields.custom.subscribe_price.value
  assign badge = p.metafields.custom.card_badge.value
  assign img_loading = 'eager'
  if lazy_load
    assign img_loading = 'lazy'
  endif
-%}
<div class="cptf__card">
  <a class="cptf__media" href="{{ p.url }}" aria-label="{{ card_title | escape }}">
    {%- if badge != blank -%}<span class="cptf__badge">{{ badge }}</span>{%- endif -%}
    {%- if p.featured_image != blank -%}
      <img
        class="cptf__image"
        src="{{ p.featured_image | image_url: width: 600 }}"
        srcset="{{ p.featured_image | image_url: width: 300 }} 300w, {{ p.featured_image | image_url: width: 600 }} 600w"
        sizes="(min-width: 990px) 20vw, 50vw"
        alt="{{ p.featured_image.alt | escape }}"
        width="{{ p.featured_image.width }}"
        height="{{ p.featured_image.height }}"
        loading="{{ img_loading }}"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'cptf__image placeholder-svg' }}
    {%- endif -%}
  </a>

  <div class="cptf__body">
    <div class="cptf__rating">
      {%- if p.metafields.judgeme.badge != blank -%}
        {{ p.metafields.judgeme.badge }}
      {%- else -%}
        <div class="jdgm-widget jdgm-preview-badge" data-id="{{ p.id }}" data-template="index"></div>
      {%- endif -%}
    </div>

    <a class="cptf__title" href="{{ p.url }}">{{ card_title }}</a>

    {%- if desc != blank -%}
      <p class="cptf__desc">{{ desc }}</p>
    {%- endif -%}

    <div class="cptf__price">
      {%- if p.compare_at_price > p.price -%}
        <s class="cptf__compare">{{ p.compare_at_price | money }}</s>
      {%- endif -%}
      <span class="cptf__price-current">{{ p.price | money }}</span>
    </div>

    {%- if sub != blank -%}
      <div class="cptf__subscribe">{{ sub }} when you <a class="cptf__subscribe-link" href="{{ p.url }}">subscribe</a></div>
    {%- endif -%}

    {%- if flavor != blank -%}
      <div class="cptf__flavor">{{ flavor }}</div>
    {%- endif -%}

    {%- assign cptf_variant = p.selected_or_first_available_variant -%}
    {%- if cptf_variant != blank -%}
      {%- assign cptf_fid = 'cptf-' | append: p.id -%}
      <product-form class="cptf__form">
        {%- form 'product', p, id: cptf_fid, class: 'cptf__atc', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ cptf_variant.id }}" class="product-variant-id"{% unless cptf_variant.available %} disabled{% endunless %}>
          <button type="submit" name="add" class="cptf__btn"{% unless cptf_variant.available %} disabled{% endunless %}>
            <span class="cptf__btn-label">
              {%- if cptf_variant.available -%}{{ view_label | default: 'Add to Cart' }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
            </span>
            <span class="cptf__btn-spinner loading-overlay__spinner hidden">
              <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
            </span>
          </button>
        {%- endform -%}
      </product-form>
    {%- else -%}
      <a class="cptf__btn" href="{{ p.url }}">{{ 'products.product.sold_out' | t }}</a>
    {%- endif -%}
  </div>
</div>
