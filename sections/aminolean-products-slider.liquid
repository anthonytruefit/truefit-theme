<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-products-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-products-slider.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {%- if section.blocks.first.settings.image != blank -%}
    @media screen and (max-width: 749px) {
      #Slider-{{ section.id }} .media::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }

    @media screen and (min-width: 750px) {
      #Slider-{{ section.id }} .media::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{%- liquid
  assign products_to_display = section.blocks.size

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and products_to_display > columns_mobile_int
    assign show_mobile_slider = true
  endif

  assign show_desktop_slider = false
  if section.settings.enable_desktop_slider and products_to_display > section.settings.columns_desktop
    assign show_desktop_slider = true
  endif
-%}

{%- if section.settings.enable_custom_styling -%}
<style>
  /* ---------- Heading ---------- */
  #shopify-section-{{ section.id }} .collection__title .title {
    {%- if section.settings.heading_color != blank -%}
    color: {{ section.settings.heading_color }} !important;
    {%- endif -%}
    {%- if section.settings.heading_custom_size > 0 -%}
    font-size: {{ section.settings.heading_custom_size }}rem !important;
    {%- endif -%}
  }

  /* ---------- Subtext / description ---------- */
  #shopify-section-{{ section.id }} .collection__description {
    {%- if section.settings.subtext_color != blank -%}
    color: {{ section.settings.subtext_color }} !important;
    {%- endif -%}
    {%- if section.settings.subtext_custom_size > 0 -%}
    font-size: {{ section.settings.subtext_custom_size }}rem !important;
    {%- endif -%}
  }
</style>
{%- endif -%}

{%- if section.settings.show_cta_button -%}
<style>
  /* ---------- CTA button ---------- */
  #shopify-section-{{ section.id }} .product-line-slide__cta-wrapper-{{ section.id }} {
    text-align: center;
    margin-top: {{ section.settings.cta_margin_top }}px;
  }
  #shopify-section-{{ section.id }} .product-line-slider__cta-{{ section.id }} {
    display: inline-block;
    {%- if section.settings.cta_gradient != blank -%}
    background-image: {{ section.settings.cta_gradient }};
    {%- endif -%}
    background-color: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_text_color }};
    font-size: {{ section.settings.cta_text_size }}rem;
    font-weight: {{ section.settings.cta_font_weight }};
    line-height: 1;
    text-decoration: none;
    border: {{ section.settings.cta_border_width }}px solid {{ section.settings.cta_border_color }};
    border-radius: {{ section.settings.cta_border_radius }}px;
    padding: {{ section.settings.cta_padding_y }}px {{ section.settings.cta_padding_x }}px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #shopify-section-{{ section.id }} .product-line-slider__cta-{{ section.id }}:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
{%- endif -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="product-line-slider__wrapper section-{{ section.id }}-padding{% if section.settings.full_width %} product-line-slider__wrapper--full-width{% endif %}">
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% endif %}{% if show_desktop_slider %} collection__title--desktop-slider{% endif %}">
      {%- if section.settings.title != blank -%}
        <h2 class="title inline-richtext center color-foreground-accent-1 {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="collection__description {{ section.settings.description_style }} rte">
          {{ section.settings.description -}}
        </div>
      {%- endif -%}
    </div>

    <slider-component class="slider-mobile-gutter{% if section.settings.full_width %} slider-component-full-width{% endif %}{% if show_mobile_slider == false %} page-width{% endif %}{% if show_desktop_slider == false and section.settings.full_width == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}">
      <ul
        id="Slider-{{ section.id }}"
        class="product-line-slider grid grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
        role="list"
        aria-label="{{ 'general.slider.name' | t }}"
      >
        {%- for block in section.blocks -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="product-line-slide grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}"
          >
            <div class="media ratio global-media-settings {% if block.settings.image == blank %} placeholder{% endif %}">
              {%- if block.settings.image -%}
                {%- assign height = block.settings.image.width
                  | divided_by: block.settings.image.aspect_ratio
                  | round
                -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag:
                    loading: 'lazy',
                    height: height,
                    sizes: '100vw',
                    widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                }}
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <h2 class="product-line-slide__heading inline-richtext {{ block.settings.heading_size }}">
              <a
                class="full-unstyled-link"
                {% if block.settings.link %}
                  href="{{ block.settings.link }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
              >
                {{ block.settings.heading }}
              </a>
            </h2>

            {%- if block.settings.subheading != blank -%}
              <div class="product-line-slide__text rte tw-text-sm" {{ block.shopify_attributes }}>
                <p>{{ block.settings.subheading }}</p>
              </div>
            {%- endif -%}
            {%- if section.settings.show_cta_button and block.settings.cta_text != blank -%}
              <div class="product-line-slide__cta-wrapper-{{ section.id }}">
                <a
                  href="{{ block.settings.cta_link | default: block.settings.link | default: '#' }}"
                  class="product-line-slider__cta-{{ section.id }}"
                >
                  {{ block.settings.cta_text }}
                </a>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
      {%- if show_mobile_slider or show_desktop_slider -%}
        <div class="slider-buttons slider-buttons--arrows-only page-width no-js-hidden">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ products_to_display }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            {% render 'icon-caret' %}
          </button>
        </div>
      {%- endif -%}
    </slider-component>
  </div>
</div>

{% schema %}
{
  "name": "AminoLean Products Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Featured collection",
      "label": "t:sections.featured-collection.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.featured-collection.settings.description.label"
    },
    {
      "type": "select",
      "id": "description_style",
      "label": "t:sections.featured-collection.settings.description_style.label",
      "options": [
        {
          "value": "body",
          "label": "t:sections.featured-collection.settings.description_style.options__1.label"
        },
        {
          "value": "subtitle",
          "label": "t:sections.featured-collection.settings.description_style.options__2.label"
        },
        {
          "value": "uppercase",
          "label": "t:sections.featured-collection.settings.description_style.options__3.label"
        }
      ],
      "default": "body"
    },
    {
      "type": "header",
      "content": "Heading & subtext styling"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_styling",
      "label": "Enable custom heading & subtext styling",
      "default": false
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "info": "Leave blank to keep the theme default."
    },
    {
      "type": "range",
      "id": "heading_custom_size",
      "label": "Heading size",
      "info": "Set to 0 to keep the size preset above.",
      "min": 0,
      "max": 6.0,
      "step": 0.1,
      "unit": "rem",
      "default": 0
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "info": "Leave blank to keep the theme default."
    },
    {
      "type": "range",
      "id": "subtext_custom_size",
      "label": "Subtext size",
      "info": "Set to 0 to keep the theme default.",
      "min": 0,
      "max": 3.0,
      "step": 0.1,
      "unit": "rem",
      "default": 0
    },
    {
      "type": "header",
      "content": "Call to action button"
    },
    {
      "type": "checkbox",
      "id": "show_cta_button",
      "label": "Show a button on each product",
      "info": "Set each product's button text and link in its own block settings below.",
      "default": false
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Button background color",
      "default": "#0A1A4F"
    },
    {
      "type": "color_background",
      "id": "cta_gradient",
      "label": "Button background gradient",
      "info": "Overrides the background color when set."
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "cta_text_size",
      "label": "Button text size",
      "min": 1.0,
      "max": 2.4,
      "step": 0.1,
      "unit": "rem",
      "default": 1.5
    },
    {
      "type": "select",
      "id": "cta_font_weight",
      "label": "Button font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "cta_border_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "cta_border_color",
      "label": "Button border color",
      "default": "#0A1A4F"
    },
    {
      "type": "range",
      "id": "cta_border_width",
      "label": "Button border width",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "cta_padding_x",
      "label": "Button horizontal padding",
      "min": 12,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "cta_padding_y",
      "label": "Button vertical padding",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "cta_margin_top",
      "label": "Space above button",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-collection.settings.columns_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.featured-collection.settings.full_width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "label": "t:sections.featured-collection.settings.enable_desktop_slider.label",
      "default": false
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "t:sections.all.colors.accent_1.label"
        },
        {
          "value": "accent-2",
          "label": "t:sections.all.colors.accent_2.label"
        },
        {
          "value": "background-1",
          "label": "t:sections.all.colors.background_1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.all.colors.background_2.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.all.colors.inverse.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header.content"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.featured-collection.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.featured-collection.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.featured-collection.settings.swipe_on_mobile.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.blocks.slide.name",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.slideshow.blocks.slide.settings.image.label"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Image slide",
          "label": "t:sections.slideshow.blocks.slide.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h4",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h4",
          "label": "t:sections.all.heading_size.label"
        },
        {
          "type": "inline_richtext",
          "id": "subheading",
          "default": "Tell your brand's story through images",
          "label": "t:sections.slideshow.blocks.slide.settings.subheading.label"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Button label",
          "label": "t:sections.slideshow.blocks.slide.settings.button_label.label",
          "info": "t:sections.slideshow.blocks.slide.settings.button_label.info"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.slideshow.blocks.slide.settings.link.label"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Button text",
          "info": "Leave blank to hide this product's button. Enable buttons and style them under the section's \"Call to action button\" settings.",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "Button link",
          "info": "Falls back to the slide link above if left blank."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AminoLean: Products Slider"
    }
  ]
}
{% endschema %}
