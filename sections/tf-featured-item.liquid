{% comment %}
  Featured Item
  -------------
  Spotlight for one hero product (content entered manually, not pulled from a
  Shopify product). Centered header stack, then a wide two-half panel (text/
  benefits + product image with optional corner badge), then a centered CTA.

  Panel background is solid OR a two-color gradient so it can be matched to
  whichever product is featured. Every color/size/text is editable.

  Mobile-first: panel stacks vertically IMAGE FIRST, then text, then CTA. Image
  is first in the DOM (so it's on top on phones); on desktop the halves sit side
  by side, and "image on right" flips the row direction so the DOM stays
  image-first for mobile.
{% endcomment %}

{%- liquid
  assign s = section.settings
  if s.panel_bg_type == 'gradient'
    assign panel_bg = 'linear-gradient(' | append: s.panel_angle | append: 'deg, ' | append: s.panel_color_1 | append: ', ' | append: s.panel_color_2 | append: ')'
  else
    assign panel_bg = s.panel_color_1
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --tffi-pt: {{ s.padding_top | times: 0.7 | round: 0 }}px;
    --tffi-pb: {{ s.padding_bottom | times: 0.7 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      --tffi-pt: {{ s.padding_top }}px;
      --tffi-pb: {{ s.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .tffit {
    background: {{ s.background }};
    padding-top: var(--tffi-pt);
    padding-bottom: var(--tffi-pb);
  }

  /* Header */
  .tffit__header {
    text-align: center;
    max-width: 72rem;
    margin: 0 auto 3.2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }
  .tffit__eyebrow {
    font-family: var(--font-body-family);
    font-weight: 500;
    text-transform: uppercase;
    line-height: 1.3;
  }
  .tffit__headline { margin: 0; font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; }
  .tffit__subhead { margin: 0; line-height: 1.5; }

  /* Panel */
  .tffit__panel {
    background: {{ panel_bg }};
    border-radius: {{ s.panel_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;          /* mobile: stacked, image first */
  }
  .tffit__media {
    position: relative;
    aspect-ratio: 1 / 1;
  }
  .tffit__media img,
  .tffit__media .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tffit__badge {
    position: absolute;
    top: 1.6rem;
    left: 1.6rem;
    z-index: 1;
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
  }
  .tffit__content {
    padding: 3.2rem 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    justify-content: center;
  }
  .tffit__support { margin: 0; line-height: 1.5; }
  .tffit__name { margin: 0; font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; }

  .tffit__bullets { list-style: none; margin: 0.6rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .tffit__bullet { display: flex; align-items: flex-start; gap: 1rem; line-height: 1.45; }
  .tffit__check { flex: 0 0 auto; width: 1.8rem; height: 1.8rem; margin-top: 0.1rem; }
  .tffit__check svg { width: 100%; height: 100%; fill: currentColor; }

  /* Desktop: two halves */
  @media screen and (min-width: 750px) {
    .tffit__panel { flex-direction: row; }
    .tffit__panel--image-right { flex-direction: row-reverse; }
    .tffit__media { flex: 1 1 50%; aspect-ratio: auto; min-height: 44rem; }
    .tffit__media img,
    .tffit__media .placeholder-svg { position: absolute; inset: 0; }
    .tffit__content { flex: 1 1 50%; padding: 4.8rem 4rem; }
  }
  @media screen and (min-width: 990px) {
    .tffit__content { padding: 6rem 5.6rem; }
  }

  /* CTA */
  .tffit__cta-wrap { text-align: center; margin-top: 3.2rem; }
  .tffit__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.8rem;
    padding: 0 3.2rem;
    border-radius: var(--buttons-radius, 0.4rem);
    border: 0.15rem solid {{ s.button_border_color }};
    background: {{ s.button_bg_color }};
    color: {{ s.button_text_color }};
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .tffit__cta:hover { opacity: 0.85; }
</style>

<div class="tffit">
  <div class="tffit__inner page-width">
    {%- if s.eyebrow != blank or s.headline != blank or s.subhead != blank -%}
      <div class="tffit__header">
        {%- if s.eyebrow != blank -%}
          <span class="tffit__eyebrow" style="color: {{ s.eyebrow_color }}; font-size: {{ s.eyebrow_size }}px; letter-spacing: {{ s.eyebrow_spacing }}px;">{{ s.eyebrow }}</span>
        {%- endif -%}
        {%- if s.headline != blank -%}
          <h2 class="tffit__headline" style="color: {{ s.headline_color }}; font-size: clamp(2.8rem, 5.5vw, {{ s.headline_size }}px);">{{ s.headline }}</h2>
        {%- endif -%}
        {%- if s.subhead != blank -%}
          <p class="tffit__subhead" style="color: {{ s.subhead_color }}; font-size: {{ s.subhead_size }}px;">{{ s.subhead }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tffit__panel{% if s.image_side == 'right' %} tffit__panel--image-right{% endif %}">
      <div class="tffit__media">
        {%- if s.show_badge and s.badge_text != blank -%}
          <span class="tffit__badge" style="background: {{ s.badge_bg }}; color: {{ s.badge_text_color }};">{{ s.badge_text }}</span>
        {%- endif -%}
        {%- if s.image != blank -%}
          {{ s.image | image_url: width: 1600 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 50vw, 100vw', widths: '500, 750, 1000, 1400, 1600', alt: s.product_name }}
        {%- else -%}
          {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="tffit__content">
        {%- if s.support != blank -%}
          <p class="tffit__support" style="color: {{ s.support_color }}; font-size: {{ s.support_size }}px;">{{ s.support }}</p>
        {%- endif -%}
        {%- if s.product_name != blank -%}
          <p class="tffit__name" style="color: {{ s.name_color }}; font-size: clamp(2.6rem, 5vw, {{ s.name_size }}px);">{{ s.product_name }}</p>
        {%- endif -%}

        {%- assign has_bullets = false -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}{%- assign has_bullets = true -%}{%- endif -%}
        {%- endfor -%}
        {%- if has_bullets -%}
          <ul class="tffit__bullets" style="color: {{ s.bullet_color }}; font-size: {{ s.bullet_size }}px;">
            {%- for block in section.blocks -%}
              {%- if block.settings.text != blank -%}
                <li class="tffit__bullet" {{ block.shopify_attributes }}>
                  <span class="tffit__check" aria-hidden="true">
                    <svg viewBox="0 0 20 20"><path d="M16.7 5.3a1 1 0 0 1 0 1.41l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 0 1 1.4-1.42l2.8 2.8 6.8-6.79a1 1 0 0 1 1.4 0z"/></svg>
                  </span>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>

    {%- if s.button_text != blank -%}
      <div class="tffit__cta-wrap">
        <a class="tffit__cta" href="{{ s.button_link | default: '#' }}">{{ s.button_text }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Item",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "NEW ITEM" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#40738D" },
    { "type": "range", "id": "eyebrow_size", "min": 9, "max": 18, "step": 1, "unit": "px", "label": "Eyebrow size", "default": 11 },
    { "type": "range", "id": "eyebrow_spacing", "min": 0, "max": 6, "step": 1, "unit": "px", "label": "Eyebrow letter-spacing", "default": 2 },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Meet [Product]." },
    { "type": "color", "id": "headline_color", "label": "Headline color", "default": "#0A1A4F" },
    { "type": "range", "id": "headline_size", "min": 22, "max": 64, "step": 1, "unit": "px", "label": "Headline size (desktop)", "default": 40 },
    { "type": "text", "id": "subhead", "label": "Sub-headline", "default": "A short benefit-driven tagline." },
    { "type": "color", "id": "subhead_color", "label": "Sub-headline color", "default": "#40738D" },
    { "type": "range", "id": "subhead_size", "min": 12, "max": 28, "step": 1, "unit": "px", "label": "Sub-headline size", "default": 17 },

    { "type": "header", "content": "Panel background" },
    {
      "type": "select", "id": "panel_bg_type", "label": "Background type", "default": "gradient",
      "options": [
        { "value": "solid", "label": "Solid color" },
        { "value": "gradient", "label": "Two-color gradient" }
      ]
    },
    { "type": "color", "id": "panel_color_1", "label": "Color 1 (solid uses this)", "default": "#0A1A4F" },
    { "type": "color", "id": "panel_color_2", "label": "Color 2 (gradient only)", "default": "#40738D" },
    { "type": "range", "id": "panel_angle", "min": 0, "max": 360, "step": 5, "unit": "deg", "label": "Gradient angle", "default": 135 },
    { "type": "range", "id": "panel_radius", "min": 0, "max": 48, "step": 2, "unit": "px", "label": "Panel corner radius", "default": 20 },

    { "type": "header", "content": "Panel content" },
    { "type": "text", "id": "support", "label": "Supporting line", "default": "Now available" },
    { "type": "color", "id": "support_color", "label": "Supporting line color", "default": "#86BCE8" },
    { "type": "range", "id": "support_size", "min": 11, "max": 22, "step": 1, "unit": "px", "label": "Supporting line size", "default": 14 },
    { "type": "text", "id": "product_name", "label": "Product name", "default": "Product Name" },
    { "type": "color", "id": "name_color", "label": "Product name color", "default": "#FFFFFF" },
    { "type": "range", "id": "name_size", "min": 22, "max": 56, "step": 1, "unit": "px", "label": "Product name size (desktop)", "default": 34 },
    { "type": "color", "id": "bullet_color", "label": "Bullet text + checkmark color", "default": "#FFFFFF" },
    { "type": "range", "id": "bullet_size", "min": 12, "max": 22, "step": 1, "unit": "px", "label": "Bullet size", "default": 15 },

    { "type": "header", "content": "Panel image" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    {
      "type": "select", "id": "image_side", "label": "Image side (desktop)", "default": "right",
      "info": "On mobile the image is always on top.",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },

    { "type": "header", "content": "Badge" },
    { "type": "checkbox", "id": "show_badge", "label": "Show badge", "default": true },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "NEW" },
    { "type": "color", "id": "badge_bg", "label": "Badge background", "default": "#C9A86A" },
    { "type": "color", "id": "badge_text_color", "label": "Badge text color", "default": "#0A1A4F" },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button link", "info": "Pick a product, collection, or page, or paste any URL." },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#0A1A4F" },
    { "type": "color", "id": "button_border_color", "label": "Button border color", "default": "#0A1A4F" },
    { "type": "color", "id": "button_bg_color", "label": "Button background color", "default": "rgba(0,0,0,0)" },

    { "type": "header", "content": "Section" },
    { "type": "color", "id": "background", "label": "Section background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 56 }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Benefit bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Bullet text", "default": "Benefit bullet" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured Item",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Clean, science-backed formula" } },
        { "type": "bullet", "settings": { "text": "No artificial junk" } },
        { "type": "bullet", "settings": { "text": "Tastes like you'll actually want it" } },
        { "type": "bullet", "settings": { "text": "Every ingredient earned its place" } }
      ]
    }
  ]
}
{% endschema %}
