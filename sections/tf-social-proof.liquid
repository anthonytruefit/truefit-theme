{% comment %}
  Social Proof
  ------------
  Centered header (eyebrow / headline / credibility line) above a horizontal
  carousel of testimonial cards. Each card = edge-to-edge rounded media (image
  OR play-on-tap video) with an overlaid name tag, then stars + pull-quote below.

  Mobile-first: 1 card + peek on phones, swipeable (scroll-snap); video stays
  unloaded until tapped (Dawn's <deferred-media>), posters lazy-load. Reuses the
  theme's SliderComponent (prev/next + scroll) and DeferredMedia, both registered
  globally in global.js, so no extra JS is needed.

  All colors/sizes/text/fonts/media are merchant-controlled. Colors are sensible
  brand defaults only; a final color pass comes later.
{% endcomment %}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --tfsp-bg: {{ s.background }};
    --tfsp-radius: {{ s.card_radius }}px;
    --tfsp-ratio: {{ s.media_ratio }};
    --tfsp-cols: {{ s.cards_desktop }};
    --tfsp-play-color: {{ s.play_color }};
    --tfsp-play-bg: {{ s.play_bg }};
    --tfsp-pt: {{ s.padding_top | times: 0.7 | round: 0 }}px;
    --tfsp-pb: {{ s.padding_bottom | times: 0.7 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      --tfsp-pt: {{ s.padding_top }}px;
      --tfsp-pb: {{ s.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .tfsp {
    background: var(--tfsp-bg, #fff);
    padding-top: var(--tfsp-pt);
    padding-bottom: var(--tfsp-pb);
  }

  /* Header */
  .tfsp__header {
    text-align: center;
    max-width: 70rem;
    margin: 0 auto 3.6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }
  .tfsp__eyebrow {
    font-family: var(--font-body-family);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    line-height: 1.3;
    margin-bottom: 1.2rem;
  }
  .tfsp__headline {
    margin: 0;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .tfsp__cred {
    margin: 0;
    line-height: 1.4;
  }

  /* Carousel track: peek + scroll-snap */
  .tfsp__track {
    list-style: none;
    margin: 0;
    padding: 0 0 1rem;
    display: flex;
    gap: 1.6rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .tfsp__track::-webkit-scrollbar { display: none; }
  .tfsp__slide {
    scroll-snap-align: start;
    flex: 0 0 84%;                 /* phone: 1 card + peek */
  }
  @media screen and (min-width: 750px) {
    .tfsp__track { gap: 2rem; }
    .tfsp__slide { flex-basis: calc((100% - 2rem) / 2.3); }   /* ~2 + peek */
  }
  @media screen and (min-width: 990px) {
    .tfsp__slide {
      flex-basis: calc((100% - var(--tfsp-cols) * 2rem) / (var(--tfsp-cols) + 0.3));
    }
  }

  .tfsp__card { display: flex; flex-direction: column; height: 100%; }

  /* Media: edge-to-edge, rounded, no bezel */
  .tfsp__media {
    position: relative;
    aspect-ratio: var(--tfsp-ratio, 4 / 5);
    border-radius: var(--tfsp-radius, 16px);
    overflow: hidden;
    background: rgba(10, 26, 79, 0.05);
  }
  .tfsp__media img,
  .tfsp__media video,
  .tfsp__media iframe,
  .tfsp__poster-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tfsp__deferred, .tfsp__poster { position: absolute; inset: 0; width: 100%; height: 100%; }
  .tfsp__poster { padding: 0; border: 0; cursor: pointer; background: none; }

  /* Play button (color/style editable) */
  .tfsp__play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 5.6rem;
    height: 5.6rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--tfsp-play-bg, #0a1a4f);
    color: var(--tfsp-play-color, #fff);
    transition: transform 0.15s ease;
  }
  .tfsp__play--outline { background: transparent; border: 0.2rem solid currentColor; }
  .tfsp__poster:hover .tfsp__play { transform: scale(1.06); }
  .tfsp__play svg { width: 2.2rem; height: 2.2rem; fill: currentColor; }

  /* Name tag overlay */
  .tfsp__nametag {
    position: absolute;
    z-index: 1;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1;
    max-width: calc(100% - 2.4rem);
  }
  .tfsp__nametag--tl { top: 1.2rem; left: 1.2rem; }
  .tfsp__nametag--tr { top: 1.2rem; right: 1.2rem; }
  .tfsp__nametag--bl { bottom: 1.2rem; left: 1.2rem; }
  .tfsp__nametag--br { bottom: 1.2rem; right: 1.2rem; }

  /* Stars + quote */
  .tfsp__stars { display: flex; gap: 0.3rem; margin: 1.6rem 0 0.8rem; }
  .tfsp__stars svg { width: 1.7rem; height: 1.7rem; fill: currentColor; }
  .tfsp__quote {
    margin: 0;
    line-height: 1.5;
    font-weight: 500;
  }
</style>

<div class="tfsp">
  <div class="tfsp__inner page-width">
    {%- if s.eyebrow != blank or s.headline != blank or s.credibility != blank -%}
      <div class="tfsp__header">
        {%- if s.eyebrow != blank -%}
          <span class="tfsp__eyebrow" style="color: {{ s.eyebrow_color }}; font-size: {{ s.eyebrow_size }}px;">{{ s.eyebrow }}</span>
        {%- endif -%}
        {%- if s.headline != blank -%}
          <h2 class="tfsp__headline" style="color: {{ s.headline_color }}; font-size: clamp(2.6rem, 5.5vw, {{ s.headline_size }}px);">{{ s.headline }}</h2>
        {%- endif -%}
        {%- if s.credibility != blank -%}
          <p class="tfsp__cred" style="color: {{ s.credibility_color }}; font-size: {{ s.credibility_size }}px;">{{ s.credibility }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <slider-component class="slider-mobile-gutter">
        <ul class="tfsp__track" id="Slider-{{ section.id }}" role="list">
          {%- for block in section.blocks -%}
            {%- liquid
              assign b = block.settings
              assign is_video = false
              if b.media_type == 'video'
                if b.video != blank or b.video_url != blank
                  assign is_video = true
                endif
              endif
              assign poster = b.poster | default: b.video.preview_image
              if b.quote_font == 'serif'
                assign quote_family = 'Georgia, "Times New Roman", serif'
              else
                assign quote_family = 'var(--font-body-family)'
              endif
            -%}
            <li class="tfsp__slide" id="Slide-{{ section.id }}-{{ forloop.index }}" {{ block.shopify_attributes }}>
              <div class="tfsp__card">
                <div class="tfsp__media">
                  {%- if is_video -%}
                    {%- assign vid = b.video.id | default: b.video_url.id -%}
                    <deferred-media class="tfsp__deferred deferred-media" data-media-id="{{ vid }}">
                      <button
                        id="Deferred-Poster-{{ section.id }}-{{ block.id }}"
                        class="tfsp__poster deferred-media__poster"
                        type="button"
                        aria-label="{{ 'sections.video.load_video' | t | default: 'Play video' }}"
                      >
                        {%- if poster != blank -%}
                          {{ poster | image_url: width: 1200 | image_tag: class: 'tfsp__poster-img', loading: 'lazy', sizes: '(min-width: 990px) 25vw, 84vw', widths: '400, 600, 800, 1200', alt: b.name_text }}
                        {%- else -%}
                          {{ 'hero-apparel-3' | placeholder_svg_tag: 'tfsp__poster-img placeholder-svg' }}
                        {%- endif -%}
                        <span class="tfsp__play{% if s.play_style == 'outline' %} tfsp__play--outline{% endif %}" aria-hidden="true">
                          <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </span>
                      </button>
                      <template>
                        {%- if b.video != blank -%}
                          {{ b.video | video_tag: image_size: '1100x', autoplay: true, loop: false, controls: true, muted: false }}
                        {%- elsif b.video_url.type == 'youtube' -%}
                          <iframe src="https://www.youtube.com/embed/{{ vid }}?enablejsapi=1&autoplay=1" class="js-youtube" allow="autoplay; encrypted-media" allowfullscreen title="{{ b.name_text | escape }}"></iframe>
                        {%- elsif b.video_url.type == 'vimeo' -%}
                          <iframe src="https://player.vimeo.com/video/{{ vid }}?autoplay=1" class="js-vimeo" allow="autoplay; encrypted-media" allowfullscreen title="{{ b.name_text | escape }}"></iframe>
                        {%- endif -%}
                      </template>
                    </deferred-media>
                  {%- elsif b.image != blank -%}
                    {{ b.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, 84vw', widths: '400, 600, 800, 1200', alt: b.name_text }}
                  {%- else -%}
                    {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}

                  {%- if b.name_position != 'hidden' and b.name_text != blank -%}
                    <span class="tfsp__nametag tfsp__nametag--{{ b.name_position }}" style="background: {{ b.name_bg }}; color: {{ b.name_color }};">{{ b.name_text }}</span>
                  {%- endif -%}
                </div>

                {%- if b.star_count > 0 -%}
                  <div class="tfsp__stars" style="color: {{ b.star_color }};" aria-label="{{ b.star_count }} out of 5 stars">
                    {%- for i in (1..b.star_count) -%}
                      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1.6l2.47 5.01 5.53.8-4 3.9.94 5.51L10 14.2l-4.94 2.62.94-5.5-4-3.9 5.53-.8z"/></svg>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if b.quote != blank -%}
                  <blockquote class="tfsp__quote" style="color: {{ b.quote_color }}; font-size: clamp(1.5rem, 4vw, {{ b.quote_size }}px); font-family: {{ quote_family }};">{{ b.quote }}</blockquote>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>

        <div class="tfsp__controls slider-buttons no-js-hidden">
          <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">{% render 'icon-caret' %}</button>
          <span class="slider-counter caption visually-hidden">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </span>
          <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">{% render 'icon-caret' %}</button>
        </div>
      </slider-component>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Social Proof",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "REAL PEOPLE, REAL RESULTS" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#40738D" },
    { "type": "range", "id": "eyebrow_size", "min": 9, "max": 18, "step": 1, "unit": "px", "label": "Eyebrow size", "default": 11 },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Join 1,000,000+ who stay true to their goals." },
    { "type": "color", "id": "headline_color", "label": "Headline color", "default": "#0A1A4F" },
    { "type": "range", "id": "headline_size", "min": 22, "max": 64, "step": 1, "unit": "px", "label": "Headline size (desktop)", "default": 34 },
    { "type": "text", "id": "credibility", "label": "Credibility line", "default": "4.8 · 3,000+ reviews · 1M+ servings delivered." },
    { "type": "color", "id": "credibility_color", "label": "Credibility color", "default": "#40738D" },
    { "type": "range", "id": "credibility_size", "min": 11, "max": 24, "step": 1, "unit": "px", "label": "Credibility size", "default": 15 },

    { "type": "header", "content": "Card layout" },
    { "type": "range", "id": "card_radius", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Card corner radius", "default": 16 },
    {
      "type": "select", "id": "media_ratio", "label": "Media aspect ratio", "default": "4 / 5",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "9 / 16", "label": "Tall (9:16)" },
        { "value": "16 / 9", "label": "Landscape (16:9)" }
      ]
    },
    { "type": "range", "id": "cards_desktop", "min": 2, "max": 5, "step": 1, "label": "Cards visible on desktop", "default": 4 },
    { "type": "color", "id": "play_color", "label": "Play button icon color", "default": "#FFFFFF" },
    { "type": "color", "id": "play_bg", "label": "Play button background", "default": "#0A1A4F" },
    {
      "type": "select", "id": "play_style", "label": "Play button style", "default": "filled",
      "options": [
        { "value": "filled", "label": "Filled circle" },
        { "value": "outline", "label": "Outline" }
      ]
    },

    { "type": "header", "content": "Section" },
    { "type": "color", "id": "background", "label": "Section background", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Testimonial card",
      "settings": [
        { "type": "header", "content": "Media" },
        {
          "type": "select", "id": "media_type", "label": "Media type", "default": "image",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video (play on tap)" }
          ]
        },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "video", "id": "video", "label": "Video (uploaded)" },
        { "type": "video_url", "id": "video_url", "label": "Video (YouTube / Vimeo link)", "accept": ["youtube", "vimeo"] },
        { "type": "image_picker", "id": "poster", "label": "Video poster / thumbnail", "info": "Shown before tap. Falls back to the uploaded video's preview." },

        { "type": "header", "content": "Quote" },
        { "type": "text", "id": "quote", "label": "Pull-quote", "default": "This is the only protein I actually look forward to drinking." },
        { "type": "color", "id": "quote_color", "label": "Quote color", "default": "#0A1A4F" },
        { "type": "range", "id": "quote_size", "min": 13, "max": 28, "step": 1, "unit": "px", "label": "Quote size", "default": 16 },
        {
          "type": "select", "id": "quote_font", "label": "Quote font", "default": "sans",
          "options": [
            { "value": "sans", "label": "Brand sans (Poppins)" },
            { "value": "serif", "label": "Serif" }
          ]
        },

        { "type": "header", "content": "Stars" },
        { "type": "range", "id": "star_count", "min": 0, "max": 5, "step": 1, "label": "Number of stars", "default": 5 },
        { "type": "color", "id": "star_color", "label": "Star color", "default": "#C9A86A" },

        { "type": "header", "content": "Name tag" },
        { "type": "text", "id": "name_text", "label": "Name / handle", "default": "@truefit" },
        {
          "type": "select", "id": "name_position", "label": "Name tag position", "default": "bl",
          "options": [
            { "value": "tl", "label": "Top left" },
            { "value": "tr", "label": "Top right" },
            { "value": "bl", "label": "Bottom left" },
            { "value": "br", "label": "Bottom right" },
            { "value": "hidden", "label": "Hidden" }
          ]
        },
        { "type": "color", "id": "name_bg", "label": "Name tag background", "default": "#0A1A4F" },
        { "type": "color", "id": "name_color", "label": "Name tag text color", "default": "#FFFFFF" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Social Proof",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
