{%- liquid
  assign slides = section.blocks | where: 'type', 'slide'
  if slides > 1
    assign is_slider = true
  else
    assign is_slider = false
  endif

  assign image_mobile = slides.first.settings.mobile_image | default: slides.first.settings.desktop_image
  assign image_desktop = slides.first.settings.desktop_image | default: slides.first.settings.mobile_image
-%}
<slideshow-component
  role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}"
>
  {%- assign slideshow_id = 'Slider-' | append: section.id -%}
  <div
    id="{{ slideshow_id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
    class="slider slider--everywhere tw-flex tw-items-stretch tw-overflow-auto [--ratio-percent:var(--mobile-aspect-padding)] tablet:[--ratio-percent:var(--desktop-aspect-padding)]"
    style="--mobile-aspect-padding:{{ 100 | divided_by: image_mobile.aspect_ratio }}%;--desktop-aspect-padding:{{ 100 | divided_by: image_desktop.aspect_ratio }}%;"
  >
    {%- for slide in slides -%}
      {%- liquid
        assign start_index = blank
        assign end_index = blank
        assign next_slide = slides[forloop.index]
        assign start_id = slide.id
        assign end_id = next_slide.id

        for block in section.blocks
          if block.id == start_id
            assign start_index = forloop.index
          elsif block.id == end_id
            assign end_index = forloop.index0
            break
          endif
        endfor
        if end_index == blank
          assign end_index = section.blocks.size
        endif
        assign block_count = end_index | minus: start_index | at_least: 0
        assign content_blocks = section.blocks | slice: start_index, block_count
        assign slide_id = 'Slide-' | append: section.id | append: '-' | append: slide.id
        render 'image-banner', banner: slide, blocks: content_blocks, wrapper_class: 'slideshow__slide', wrapper_id: slide_id, height: section.settings.image_height, index: forloop.index
      -%}
    {%- endfor -%}
  </div>
  {%- if slides.size > 1 -%}
    <div class="page-width slider-buttons no-js-hidden tw-flex tw-w-full tw-items-center tw-relative page-width {% if section.settings.auto_rotate %}slider-buttons--justify-center{% else %}slider-buttons--justify-between{% endif %}">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {% render 'icon-caret' %}
      </button>
      <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' %} caption{% endif %}">
        {%- if section.settings.slider_visual == 'counter' -%}
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ slides.size }}</span>
        {%- else -%}
          <div class="slideshow__control-wrapper">
            {%- for block in slides -%}
              <button
                class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                aria-controls="Slider-{{ section.id }}"
              >
                {%- if section.settings.slider_visual == 'numbers' -%}
                  {{ forloop.index -}}
                {%- else -%}
                  <span class="dot"></span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {% render 'icon-caret' %}
      </button>

      {%- if section.settings.auto_rotate -%}
        <button
          type="button"
          class="slideshow__autoplay tw-w-44 tw-h-44 no-js-hidden{% if section.settings.auto_rotate == false %} slideshow__autoplay--paused{% endif %}"
          aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
        >
          {%- render 'icon-pause' -%}
          {%- render 'icon-play' -%}
        </button>
      {%- endif -%}
    </div>
    <noscript>
      <div class="slider-buttons">
        <div class="slider-counter">
          {%- for block in slides -%}
            <a
              href="#Slide-{{ section.id }}-{{ forloop.index }}"
              class="slider-counter__link link"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
            >
              {{ forloop.index }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </noscript>
  {%- endif -%}
</slideshow-component>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
