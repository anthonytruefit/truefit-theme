  ],
  "presets": [
    {
      "name": "Image Banner Slideshow",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "heading"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
