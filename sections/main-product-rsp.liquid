{%- comment -%} tf-pdp: inline quantity stepper merged with add-to-cart (resync) {%- endcomment -%}
<section
  id="MainProduct-{{ section.id }}"
  class="page-width tw-px-24 tablet:tw-px-32 desktop:tw-px-50 section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'section-main-product-rsp.css' | asset_url | stylesheet_tag }}
  {{ 'recharge-overrides.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
  {%- if product.quantity_price_breaks_configured? -%}
    {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

 {%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .selling-plan-price__discount-tag {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    margin-left: 8px;
    padding: 4px 8px;
    border-radius: 999px;
    background-color: #e53935 !important;
    color: #ffffff !important;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    vertical-align: middle;
  }

  @media screen and (max-width: 749px) {
    .selling-plan-price__discount-tag {
      display: inline-flex !important;
      align-items: center;
      justify-content: center;
      background-color: #e53935 !important;
      color: #ffffff !important;
      padding: 4px 8px !important;
      border-radius: 999px !important;
      font-size: 11px;
      margin-left: 6px;
      line-height: 1;
      white-space: nowrap;
    }
  }
{%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-flavor-picker.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'selling-plan-price.js' | asset_url }}" defer="defer"></script>
  {%- if product.quantity_price_breaks_configured? -%}
    <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
  {% if section.settings.image_zoom == 'hover' %}
    <script id="EnableZoomOnHover-main" src="{{ 'magnify.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}
    {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}

  {%- assign product_picker_products = section.blocks | where: 'type', 'product_picker_product' -%}
  {%- assign rendered_product_picker = false -%}

  <div
    class="product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col {% if product.media.size > 0 %}grid--2-col-tablet{% else %}product--no-media{% endif %}"
    {%- if product.metafields.product_theme.accent_color.value.alpha > 0 %}
      style="--color-accent:{%- render 'dynamic-color-to-rgb', color: product.metafields.product_theme.accent_color.value -%}"
    {%- endif -%}
  >
    <div class="grid__item product__media-wrapper{% if section.settings.media_position == 'right' %} medium-hide large-up-hide{% endif %}">
      {% render 'product-media-gallery', variant_images: variant_images %}
    </div>
    <div class="product__info-wrapper grid__item{% if settings.page_width > 1400 and section.settings.media_size == "small" %} product__info-wrapper--extra-padding{% endif %}">
      <product-info
        id="ProductInfo-{{ section.id }}"
        data-section="{{ section.id }}"
        data-url="{{ product.url }}"
        class="product__info-container{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
      >
        {%- assign product_form_id = 'product-form-' | append: section.id -%}
        {%- comment -%} If a tf_quantity block is present, render the stepper inline beside the
          Add to Cart button (in buy-buttons) so it merges with the button. {%- endcomment -%}
        {%- assign has_tf_quantity = false -%}
        {%- for b in section.blocks -%}
          {%- if b.type == 'tf_quantity' -%}{%- assign has_tf_quantity = true -%}{%- endif -%}
        {%- endfor -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'text' -%}
              {%- liquid
                assign text_styles = ''
                if block.settings.custom_text_size > 0
                  assign text_styles = text_styles | append: 'font-size:' | append: block.settings.custom_text_size | append: 'rem !important;'
                endif
                if block.settings.custom_text_color != blank
                  assign text_styles = text_styles | append: 'color:' | append: block.settings.custom_text_color | append: ' !important;'
                endif
                if block.settings.custom_text_align != blank
                  assign text_styles = text_styles | append: 'text-align:' | append: block.settings.custom_text_align | append: ';'
                endif
                if block.settings.custom_text_weight != blank
                  assign text_styles = text_styles | append: 'font-weight:' | append: block.settings.custom_text_weight | append: ';'
                endif
              -%}
              <p
                class="tw-mt-12 product__text inline-richtext{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}"
                {% if text_styles != blank %}style="{{ text_styles }}"{% endif %}
                {{ block.shopify_attributes }}
              >
                {{- block.settings.text -}}
              </p>

            {%- when 'alix_collab_title' -%}
              {%- assign main_title = block.settings.title | default: product.title -%}
              <div class="product__title" {{ block.shopify_attributes }}>
                <h1 class="tw-text-foreground tw-text-4xl">
                  <span>{{ main_title | escape }}</span>
                  <span class="tw-sr-only">x Alix Earle</span>
                </h1>
                <div class="product-collab-image-wrapper">
                  {%- render 'alix-earle-collab' -%}
                </div>
                <a href="{{ product.url }}" class="product__title">
                  <h2 class="h1">
                    {{ product.title | escape }}
                  </h2>
                </a>
              </div>
            {%- when 'collab_title' -%}
              {%- assign main_title = block.settings.title | default: product.title -%}
              <div class="product__title" {{ block.shopify_attributes }}>
                <h1 class="tw-text-foreground tw-text-4xl">
                  <span>{{ main_title | escape }}</span>
                  {%- if block.settings.hidden_name != blank %}
                    <span class="tw-sr-only">{{ block.settings.hidden_name }}</span>
                  {%- endif -%}
                </h1>
                {%- if block.settings.image != blank -%}
                  {%- assign collab_sizes = block.settings.image.width | append: 'px' -%}
                  <div class="product-collab-image-wrapper" style="margin-top:{{block.settings.image_top_margin}}px;">
                    {{
                      block.settings.image
                      | image_url: width: 380
                      | image_tag:
                        width: block.settings.image.width,
                        height: block.settings.image.height,
                        sizes: collab_sizes,
                        widths: '190, 380, 570, 760, 950, 1500',
                        loading: 'lazy'
                    }}
                  </div>
                {%- endif -%}
                <a href="{{ product.url }}" class="product__title">
                  <h2 class="h1">
                    {{ product.title | escape }}
                  </h2>
                </a>
              </div>
            {%- when 'title' -%}
              {%- assign main_title = block.settings.title | default: product.title -%}
              {%- if block.settings.remove_flavor_name -%}
                {%- assign main_title = main_title | split: '-' | first -%}
              {%- endif -%}
              <div class="product__title" {{ block.shopify_attributes }}>
                <h1 class="tw-text-foreground tw-text-4xl">{{ main_title | escape }}</h1>
                <a href="{{ product.url }}" class="product__title">
                  <h2 class="h1">
                    {{ product.title | escape }}
                  </h2>
                </a>
              </div>
            {%- when 'reviews_badge_price' -%}
              <div
                class="product-reviews-badge-price tw-mt-12 tw-flex tw-justify-between"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.badge_image == blank -%}
                  {%- unless block.settings.hide_if_no_reviews and product.metafields.spr.reviews == blank -%}
                    <a
                      class="shopify-product-reviews-badge__wrapper"
                      href="#shopify-product-reviews"
                      aria-label="Read product reviews"
                      onclick="var el=document.querySelector('#shopify-product-reviews[data-id=\'{{ product.id }}\']');el&&el.scrollIntoView({behavior:'smooth'});return false;"
                    >
                      <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
                    </a>
                  {%- endunless -%}
                {%- else -%}
                  <div class="product-reviews-badge-image__wrapper">
                    {%- assign badge_height = 152.0 | divided_by: block.settings.badge_image.aspect_ratio | round -%}
                    {{
                      block.settings.badge_image
                      | image_url: width: 750
                      | image_tag: width: 152, height: badge_height, sizes: '152px', loading: 'lazy'
                    }}
                  </div>
                {%- endif -%}

                <div
                  class="no-js-hidden product-price-container tw-self-center"
                  id="price-{{ section.id }}"
                  role="status"
                >
                  {%- liquid
                    assign current_variant = product.selected_or_first_available_variant
                    assign variant_price = current_variant.price
                    assign has_selling_plan = false
                    assign selling_plan_price = variant_price
                    if current_variant.selling_plan_allocations.size > 0
                      assign has_selling_plan = true
                      assign first_allocation = current_variant.selling_plan_allocations.first
                      assign selling_plan_price = first_allocation.per_delivery_price | times: 0.82
                    endif
                  -%}
                  <selling-plan-price
                    class="selling-plan-price"
                    data-section-id="{{ section.id }}"
                    data-variant-price="{{ variant_price }}"
                    data-selling-plan-price="{{ selling_plan_price }}"
                    data-has-selling-plan="{{ has_selling_plan }}"
                    data-currency-symbol="{{ cart.currency.symbol }}"
                    data-money-format="{{ shop.money_format }}"
                  >
                    <div class="selling-plan-price__regular" data-price-view="regular">
                      {%- render 'price',
                        product: product,
                        use_variant: true,
                        show_badges: false,
                        price_class: 'price--large'
                      -%}
                    </div>
                    <div class="selling-plan-price__subscription" data-price-view="subscription" style="display: none;">
  {%- liquid
    assign discount_amount = variant_price | minus: selling_plan_price
    assign discount_percent = discount_amount | times: 100.0 | divided_by: variant_price | round
  -%}
  <div class="price price--large price--on-sale">
    <div class="price__container">
      <div class="price__sale">
        <span class="visually-hidden">{{ 'products.product.price.regular_price' | t }}</span>
        <span>
          <s class="price-item price-item--regular" data-compare-price>
            {{ variant_price | money }}
          </s>
        </span>

        <span class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</span>
        <span class="price-item price-item--sale price-item--last" data-selling-plan-price-display>
          {{ selling_plan_price | money }}
        </span>

        <span class="selling-plan-price__discount-tag" data-discount-tag>
          Save {{ discount_percent }}%
        </span>
      </div>
    </div>
  </div>
</div>
                  </selling-plan-price>
                </div>
              </div>

            {%- when 'price' -%}
              <div class="no-js-hidden" id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                {%- render 'price',
                  product: product,
                  use_variant: true,
                  show_badges: block.settings.show_badges,
                  price_class: 'price--large'
                -%}
              </div>
              {%- if product.quantity_price_breaks_configured? -%}
                <div class="volume-pricing-note" id="Volume-Note-{{ section.id }}">
                  <span>{{ 'products.product.volume_pricing.note' | t }}</span>
                </div>
              {%- endif -%}
              <div class="product__tax caption rte">
                {%- if cart.taxes_included -%}
                  {{ 'products.product.include_taxes' | t }}
                {%- endif -%}
                {%- if shop.shipping_policy.body != blank -%}
                  {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                {%- endif -%}
              </div>
              <div {{ block.shopify_attributes }}>
                {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                {%- form 'product',
                  product,
                  data-productid: product.id,
                  id: product_form_installment_id,
                  class: 'installment caption-large'
                -%}
                  <input
                    type="hidden"
                    name="id"
                    data-productid="{{ product.id }}"
                    value="{{ product.selected_or_first_available_variant.id }}"
                  >
                  {{ form | payment_terms }}
                {%- endform -%}
              </div>
            {%- when 'inventory' -%}
              <p
                class="product__inventory no-js-hidden{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                {{ block.shopify_attributes }}
                id="Inventory-{{ section.id }}"
                role="status"
              >
                {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                  {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity
                        <= block.settings.inventory_threshold
                    -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(238,148,65, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(238,148,65)"/>
                      </svg>
                      {%- if block.settings.show_inventory_quantity -%}
                        {{-
                          'products.product.inventory_low_stock_show_count'
                          | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                        -}}
                      {%- else -%}
                        {{- 'products.product.inventory_low_stock' | t -}}
                      {%- endif -%}
                    {%- else -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                      </svg>
                      {%- if block.settings.show_inventory_quantity -%}
                        {{-
                          'products.product.inventory_in_stock_show_count'
                          | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                        -}}
                      {%- else -%}
                        {{- 'products.product.inventory_in_stock' | t -}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- else -%}
                    {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(62,214,96, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(62,214,96)"/>
                      </svg>
                      {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                    {%- else -%}
                      <svg width="15" height="15" aria-hidden="true">
                        <circle cx="7.5" cy="7.5" r="7.5" fill="rgb(200,200,200, 0.3)"/>
                        <circle cx="7.5" cy="7.5" r="5" stroke="rgb(255, 255, 255)" stroke-width="1" fill="rgb(200,200,200)"/>
                      </svg>
                      {{- 'products.product.inventory_out_of_stock' | t -}}
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
              </p>
            {%- when 'description' -%}
              {%- if product.description != blank -%}
                <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
                  {{ product.description }}
                </div>
              {%- endif -%}
            {%- when 'sku' -%}
              <p
                class="product__sku no-js-hidden{% if block.settings.text_style == 'uppercase' %} caption-with-letter-spacing{% elsif block.settings.text_style == 'subtitle' %} subtitle{% endif %}{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                id="Sku-{{ section.id }}"
                role="status"
                {{ block.shopify_attributes }}
              >
                <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                {{- product.selected_or_first_available_variant.sku -}}
              </p>
            {%- when 'custom_liquid' -%}
              {{ block.settings.custom_liquid }}
            {%- when 'collapsible_tab' -%}
              <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                <details id="Details-{{ block.id }}-{{ section.id }}">
                  <summary>
                    <div class="summary__title">
                      {% render 'icon-accordion', icon: block.settings.icon %}
                      <h2 class="h4 accordion__title inline-richtext">
                        {{ block.settings.heading | default: block.settings.page.title }}
                      </h2>
                    </div>
                    {% render 'icon-caret' %}
                  </summary>
                  <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                    {{ block.settings.content }}
                    {{ block.settings.page.content }}
                  </div>
                </details>
              </div>
            {%- when 'quantity_selector' -%}
              <div
                id="Quantity-Form-{{ section.id }}"
                class="product-form__input product-form__quantity{% if settings.inputs_shadow_vertical_offset != 0 and settings.inputs_shadow_vertical_offset < 0 %} product-form__quantity-top{% endif %}"
                {{ block.shopify_attributes }}
              >
                {% comment %} TODO: enable theme-check once `item_count_for_variant` is accepted as valid filter {% endcomment %}
                {% # theme-check-disable %}
                {%- assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id -%}
                {% # theme-check-enable %}
                <label class="quantity__label form__label" for="Quantity-{{ section.id }}">
                  {{ 'products.product.quantity.label' | t }}
                  <span class="quantity__rules-cart no-js-hidden{% if cart_qty == 0 %} hidden{% endif %}">
                    <span class="hidden loading-overlay">
                      <span class="loading-overlay__spinner">
                        <svg
                          aria-hidden="true"
                          focusable="false"
                          class="spinner"
                          viewBox="0 0 66 66"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </span>
                    </span>
                    <span
                      >(
                      {{- 'products.product.quantity.in_cart_html' | t: quantity: cart_qty -}}
                      )</span
                    >
                  </span>
                </label>
                <div class="price-per-item__container">
                  <quantity-input class="quantity" data-url="{{ product.url }}" data-section="{{ section.id }}">
                    <button class="quantity__button no-js-hidden" name="minus" type="button">
                      <span class="visually-hidden">
                        {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                      </span>
                      {% render 'icon-minus' %}
                    </button>
                    <input
                      class="quantity__input"
                      type="number"
                      name="quantity"
                      id="Quantity-{{ section.id }}"
                      data-cart-quantity="{{ cart_qty }}"
                      data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                      min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                      {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                        data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                        max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                      {% endif %}
                      step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                      value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                      form="{{ product_form_id }}"
                    >
                    <button class="quantity__button no-js-hidden" name="plus" type="button">
                      <span class="visually-hidden">
                        {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                      </span>
                      {% render 'icon-plus' %}
                    </button>
                  </quantity-input>
                  {%- liquid
                    assign volume_pricing_array = product.selected_or_first_available_variant.quantity_price_breaks | sort: 'quantity' | reverse
                    assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.min
                    if cart_qty > 0
                      assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.increment
                    endif
                  -%}
                  {%- if product.quantity_price_breaks_configured? -%}
                    <price-per-item
                      class="no-js-hidden"
                      id="Price-Per-Item-{{ section.id }}"
                      data-section-id="{{ section.id }}"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    >
                      {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                        {%- assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price -%}
                        <div class="price-per-item">
                          {%- if variant_price_compare -%}
                            <dl class="price-per-item--current">
                              <dt class="visually-hidden">
                                {{ 'products.product.price.regular_price' | t }}
                              </dt>
                              <dd>
                                <s class="variant-item__old-price">
                                  {{ variant_price_compare | money_with_currency }}
                                </s>
                              </dd>
                            </dl>
                          {%- endif -%}
                          {%- if current_qty_for_volume_pricing < volume_pricing_array.last.minimum_quantity -%}
                            {%- assign variant_price = product.selected_or_first_available_variant.price
                              | money_with_currency
                            -%}
                            <span class="price-per-item--current">
                              {{- 'products.product.volume_pricing.price_at_each' | t: price: variant_price -}}
                            </span>
                          {%- else -%}
                            {%- for price_break in volume_pricing_array -%}
                              {%- if current_qty_for_volume_pricing >= price_break.minimum_quantity -%}
                                {%- assign price_break_price = price_break.price | money_with_currency -%}
                                <span class="price-per-item--current">
                                  {{- 'products.product.volume_pricing.price_at_each' | t: price: price_break_price -}}
                                </span>
                                {%- break -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- endif -%}
                        </div>
                      {%- else -%}
                        {%- assign variant_price = product.selected_or_first_available_variant.price
                          | money_with_currency
                        -%}
                        {%- assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price -%}
                        <div class="price-per-item">
                          {%- if variant_price_compare -%}
                            <dl class="price-per-item--current">
                              <dt class="visually-hidden">
                                {{ 'products.product.price.regular_price' | t }}
                              </dt>
                              <dd>
                                <s class="variant-item__old-price">
                                  {{ variant_price_compare | money_with_currency }}
                                </s>
                              </dd>
                              <dt class="visually-hidden">
                                {{ 'products.product.price.sale_price' | t }}
                              </dt>
                              <dd>
                                <span class="price-per-item--current">
                                  {{- 'products.product.volume_pricing.price_at_each' | t: price: variant_price -}}
                                </span>
                              </dd>
                            </dl>
                          {%- else -%}
                            <span class="price-per-item--current">
                              {{- 'products.product.volume_pricing.price_at_each' | t: price: variant_price -}}
                            </span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </price-per-item>
                  {%- endif -%}
                </div>
                <div class="quantity__rules caption no-js-hidden" id="Quantity-Rules-{{ section.id }}">
                  {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 -%}
                    <span class="divider">
                      {{-
                        'products.product.quantity.multiples_of'
                        | t: quantity: product.selected_or_first_available_variant.quantity_rule.increment
                      -}}
                    </span>
                  {%- endif -%}
                  {%- if product.selected_or_first_available_variant.quantity_rule.min > 1 -%}
                    <span class="divider">
                      {{-
                        'products.product.quantity.minimum_of'
                        | t: quantity: product.selected_or_first_available_variant.quantity_rule.min
                      -}}
                    </span>
                  {%- endif -%}
                  {%- if product.selected_or_first_available_variant.quantity_rule.max != null -%}
                    <span class="divider">
                      {{-
                        'products.product.quantity.maximum_of'
                        | t: quantity: product.selected_or_first_available_variant.quantity_rule.max
                      -}}
                    </span>
                  {%- endif -%}
                </div>
                {%- if product.quantity_price_breaks_configured? -%}
                  <volume-pricing class="parent-display no-js-hidden" id="Volume-{{ section.id }}">
                    {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                      <span class="caption-large">{{ 'products.product.volume_pricing.title' | t }}</span>
                      <ul class="list-unstyled no-js-hidden">
                        <li>
                          <span>{{ product.selected_or_first_available_variant.quantity_rule.min }}+</span>
                          {%- assign price = product.selected_or_first_available_variant.price | money_with_currency -%}
                          <span data-text="{{ 'products.product.volume_pricing.price_at_each' | t: price: variant_price }}">
                            {{- 'sections.quick_order_list.each' | t: money: price -}}
                          </span>
                        </li>
                        {%- for price_break in product.selected_or_first_available_variant.quantity_price_breaks -%}
                          {%- assign price_break_price = price_break.price | money_with_currency -%}
                          <li class="{%- if forloop.index >= 3 -%}show-more-item hidden{%- endif -%}">
                            <span>
                              {{- price_break.minimum_quantity -}}
                              <span aria-hidden="true">+</span></span
                            >
                            <span data-text="{{ 'products.product.volume_pricing.price_at_each' | t: price: price_break_price }}">
                              {{- 'sections.quick_order_list.each' | t: money: price_break_price -}}
                            </span>
                          </li>
                        {%- endfor -%}
                      </ul>
                      {%- if product.selected_or_first_available_variant.quantity_price_breaks.size >= 3 -%}
                        <show-more-button>
                          <button
                            class="button-show-more link underlined-link"
                            id="Show-More-{{ section.id }}"
                            type="button"
                          >
                            <span class="label-show-more label-text"
                              ><span aria-hidden="true">+ </span>{{ 'products.facets.show_more' | t }}
                            </span>
                          </button>
                        </show-more-button>
                      {%- endif -%}
                    {%- endif -%}
                  </volume-pricing>
                {%- endif -%}
              </div>
            {%- when 'tf_quantity' -%}
              {%- comment -%} Enable flag only; the stepper renders inline beside the Add to
                Cart button via buy-buttons (inline_quantity), so it sits next to the button
                regardless of placement, bundle builder, or dynamic checkout. {%- endcomment -%}
              <span class="tf-quantity-flag" {{ block.shopify_attributes }} hidden></span>
            {%- when 'popup' -%}
              <modal-opener
                class="product-popup-modal__opener no-js-hidden quick-add-hidden"
                data-modal="#PopupModal-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <button
                  id="ProductPopup-{{ block.id }}"
                  class="product-popup-modal__button link"
                  type="button"
                  aria-haspopup="dialog"
                >
                  {{ block.settings.text | default: block.settings.page.title }}
                </button>
              </modal-opener>
              <a href="{{ block.settings.page.url }}" class="product-popup-modal__button link no-js">
                {{- block.settings.text -}}
              </a>
            {%- when 'share' -%}
              {% assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin %}
              {% render 'share-button', block: block, share_link: share_url %}
            {%- when 'product_picker_product' -%}
              {%- liquid
                if rendered_product_picker
                  continue
                endif
                assign rendered_product_picker = true
                assign product_picker_product_blocks = section.blocks | where: 'type', 'product_picker_product'
                assign product_picker_list_block = section.blocks | where: 'type', 'product_picker_list' | first
                if product_picker_list_block and product_picker_list_block.settings.horizontal_layout == false
                  assign horizontal_layout = false
                else
                  assign horizontal_layout = true
                endif
              -%}

              <div id="ProductPicker-{{ section.id }}" class="product-picker-container">
                <product-flavor-picker
                  data-section="{{ section.id }}"
                  data-url="{{ product.url }}"
                >
                  <div class="form__label" id="flavor-label">Choose Product</div>
                  <nav aria-labelledby="flavor-label">
                    <ul class="product-picker-list{% if horizontal_layout %} product-picker-list--horizontal{% endif %}">
                      {%- liquid
                        for block in product_picker_product_blocks
                          if block.settings.icon == blank or block.settings.product == blank
                            continue
                          endif
                          assign label = block.settings.title | default: block_product.options_by_name.Flavor.values.first
                          assign accent_color = block.settings.product.metafields.product_theme.accent_color.value

                          render 'product-picker-item', block: block, current_product: product, picker_product: block.settings.product, index0: forloop.index0, label: label, accent_color: accent_color, icon: block.settings.icon
                        endfor
                      -%}
                    </ul>
                  </nav>
                </product-flavor-picker>
              </div>

              {%- capture product_props -%}
                [
                  {%- for block in product_picker_product_blocks -%}
                    {%- capture color -%}
                      {%- render 'dynamic-color-to-rgb', color: block.settings.product.metafields.product_theme.accent_color.value -%}
                    {%- endcapture -%}
                    {
                      "price": {{ block.settings.product.price | json }},
                      "handle": {{ block.settings.product.handle | json }},
                      "color": {{ color | json }},
                      "icon": {{ block.settings.icon | image_url: width: 96 | json }},
                      "title": {{ block.settings.product.title | json }},
                      "label": {{ block.settings.title | default: block.settings.product.options_by_name.Flavor.values.first | default: '' | json }},
                      "image": {{ block.settings.product.featured_image | image_url: width: 200 | json  }}
                    }{%- if forloop.last == false -%},{%- endif -%}
                  {%- endfor -%}
                ]
              {%- endcapture -%}

            {%- when 'flavor_picker' -%}
              {%- liquid
                assign flavor_product_list = blank
                if block.settings.product_list.count > 0 and product.metafields.flavor_picker.icon.value != blank
                  assign flavor_product_ids = block.settings.product_list | map: 'id'
                  if flavor_product_ids contains product.id
                    assign flavor_product_list = block.settings.product_list
                  endif
                endif
                if block.settings.horizontal_layout == false
                  assign horizontal_layout = false
                else
                  assign horizontal_layout = true
                endif
              -%}
              {%- if flavor_product_list != blank -%}
                <div
                  id="ProductPicker-{{ section.id }}"
                  class="product-picker-container product-picker-container--flavor-picker"
                >
                  <product-flavor-picker
                    data-section="{{ section.id }}"
                    data-url="{{ product.url }}"
                  >
                    <div class="form__label tw-text-sm tw-tracking-wider tw-uppercase tw-font-medium" id="flavor-label">
                      Flavor
                    </div>
                    <nav aria-labelledby="flavor-label">
                      <ul class="product-picker-list{% if horizontal_layout %} product-picker-list--horizontal{% endif %}">
                        {%- liquid
                          assign selected_variant = product.selected_or_first_available_variant
                          for flavor_product in flavor_product_list
                            assign flavor_picker_icon = flavor_product.metafields.flavor_picker.icon.value
                            if flavor_picker_icon == blank
                              continue
                            endif
                            assign accent_color = flavor_product.metafields.product_theme.accent_color.value
                            assign flavor = flavor_product.metafields.flavor_picker.flavor_short.value | default: flavor_product.options_by_name.Flavor.values.first
                            render 'product-picker-item', current_product: product, picker_product: flavor_product, index0: forloop.index0, label: flavor, accent_color: accent_color, icon: flavor_picker_icon
                          endfor
                        -%}
                      </ul>
                    </nav>
                  </product-flavor-picker>
                </div>
              {%- endif -%}

            {%- when 'custom_flavor_swatch' -%}
              {%- liquid
                assign swatch_url = block.settings.link
                if swatch_url == blank and block.settings.link_product != blank
                  assign swatch_url = block.settings.link_product.url
                endif
                assign is_current = false
                if block.settings.link_product != blank and block.settings.link_product.id == product.id
                  assign is_current = true
                endif
              -%}
              <div class="custom-flavor-swatch-{{ section.id }}{% if is_current %} is-current{% endif %}" {{ block.shopify_attributes }}>
                <a href="{{ swatch_url | default: '#' }}" class="custom-flavor-swatch__link-{{ section.id }}" aria-label="{{ block.settings.caption | escape }}">
                  <span class="custom-flavor-swatch__media-{{ section.id }}">
                    {%- if block.settings.image != blank -%}
                      <img
                        src="{{ block.settings.image | image_url: width: 280 }}"
                        srcset="{{ block.settings.image | image_url: width: 140 }} 140w, {{ block.settings.image | image_url: width: 280 }} 280w"
                        sizes="140px"
                        alt="{{ block.settings.caption | escape }}"
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                        loading="lazy"
                        class="custom-flavor-swatch__image-{{ section.id }}"
                      >
                    {%- else -%}
                      <span class="custom-flavor-swatch__image-{{ section.id }} custom-flavor-swatch__placeholder-{{ section.id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </span>
                    {%- endif -%}
                  </span>
                  {%- if block.settings.caption != blank -%}
                    <span class="custom-flavor-swatch__caption-{{ section.id }}">{{ block.settings.caption }}</span>
                  {%- endif -%}
                  {%- if block.settings.size_text != blank -%}
                    <span class="custom-flavor-swatch__size-{{ section.id }}">{{ block.settings.size_text }}</span>
                  {%- endif -%}
                  {%- if block.settings.tag_text != blank -%}
                    <span class="custom-flavor-swatch__tag-{{ section.id }}">{{ block.settings.tag_text }}</span>
                  {%- endif -%}
                </a>
              </div>

            {%- when 'variant_picker' -%}
              {%- assign icon_blocks = section.blocks | where: 'type', 'product_option_icon' %}

              {% render 'product-variant-picker',
                product: product,
                block: block,
                product_form_id: product_form_id,
                icons_metaobject_handle: block.settings.icons_metaobject_handle,
                icon_blocks: icon_blocks
              %}

            {%- when 'buy_buttons' -%}
              {%- liquid
                assign bundle_options = section.blocks | where: 'type', 'bundle_option'
                assign bundle_picker_block = section.blocks | where: 'type', 'bundle_picker' | first
                assign bundle_builder = blank
              -%}
              {%- if bundle_options.size > 0 -%}
                {%- capture bundle_props -%}
                [
                  {%- for bundle_option in bundle_options -%}
                    {%- liquid 
                      assign bundle_option_title = bundle_option.settings.title
                      assign bundle_option_image = bundle_option.settings.image
                      assign bundle_option_badge = bundle_option.settings.badge
                      assign bundle_option_bundler_app_code = bundle_option.settings.bundler_app_code
                      assign bundle_option_filter = bundle_option.settings.filter
                    -%}
                    {
                      "title": {{ bundle_option_title | json }},
                      "image": {{ bundle_option_image | image_url: width: 200 | json }},
                      "badge": {{ bundle_option_badge | json }},
                      "bundler_app_code": {{ bundle_option_bundler_app_code | json }},
                      "builder_heading": {{ bundle_option.settings.builder_heading | json }},
                      "preselect_products": {{ bundle_option.settings.preselect_products | json }}
                    }{%- if forloop.last == false -%},{%- endif -%}
                  {%- endfor -%}
                ]
              {%- endcapture -%}
                {%- capture bundle_builder -%}
                {%- if product.metafields.product_theme.accent_color.value.alpha > 0 -%}
                  {%- capture product_color -%}
                    {%- render 'dynamic-color-to-rgb', color: product.metafields.product_theme.accent_color.value -%}
                  {%- endcapture -%}
                {%- else -%}
                  {%- assign product_color = blank -%}
                {%-  endif -%}
                <bundle-form
                  id="bundle-form-{{ block.id }}"
                  class="tw-block tw-mb-24"
                  products="{{ product_props | escape }}"
                  bundles="{{ bundle_props | escape }}"
                  product="{{ product | json | escape }}"
                  variant="{{ product.selected_or_first_available_variant.id }}"
                  subscribable="{% if product.selected_or_first_available_variant.selling_plan_allocations.size > 0 %}true{% else %}false{% endif %}"
                  picker-title="{{ bundle_picker_block.settings.title | default: 'Choose Your Pack' | escape }}"
                  single-option-name="{{ bundle_picker_block.settings.single_option_name | default: 'Single Pack' | escape }}"
                  {% if bundle_picker_block.settings.single_option_image %}single-option-image="{{ bundle_picker_block.settings.single_option_image | image_url: width: 200 }}"{% endif %}
                  style="{% if product_color != blank %}--color-accent:{{ product_color }};{% endif %}--color-accent-rgb:rgb(var(--color-accent));"
                ></bundle-form>
              {%- endcapture -%}
              {%- endif -%}
              {%- render 'buy-buttons',
                block: block,
                product: product,
                product_form_id: product_form_id,
                section_id: section.id,
                show_pickup_availability: true,
                bundle_builder: bundle_builder,
                inline_quantity: has_tf_quantity
              -%}
            {%- when 'fbt' -%}
              {%- liquid
                assign comp1 = block.settings.companion_1
                assign comp2 = block.settings.companion_2
              -%}
              {%- if comp1 != blank or comp2 != blank -%}
                {%- liquid
                  assign fbt_handles = product.handle
                  if comp1 != blank
                    assign fbt_handles = fbt_handles | append: '~' | append: comp1.handle
                  endif
                  if comp2 != blank
                    assign fbt_handles = fbt_handles | append: '~' | append: comp2.handle
                  endif
                  assign fbt_list = fbt_handles | split: '~'
                  assign fbt_total = 0
                  assign fbt_rendered = 0
                  assign fbt_checked = 0
                -%}
                {%- style -%}
                  #shopify-section-{{ section.id }} .fbt { display: block; width: 100%; margin-top: 2.4rem; }
                  #shopify-section-{{ section.id }} .fbt__heading { font-size: 1.6rem; font-weight: 500; letter-spacing: -0.02em; color: var(--tf-navy,#0a1a4f); margin: 0 0 1.6rem; }
                  #shopify-section-{{ section.id }} .fbt__row { display: flex; align-items: center; gap: 1rem; }
                  #shopify-section-{{ section.id }} .fbt__card { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.6rem; padding: 1.2rem 0.8rem; background: {{ block.settings.fbt_card_bg }}; border: 0.1rem solid {{ block.settings.fbt_card_border }}; border-radius: {{ block.settings.fbt_card_radius }}px; cursor: pointer; position: relative; }
                  #shopify-section-{{ section.id }} .fbt__check { position: absolute; top: 0.8rem; left: 0.8rem; width: 2rem; height: 2rem; accent-color: {{ block.settings.fbt_check_color }}; cursor: pointer; margin: 0; }
                  #shopify-section-{{ section.id }} .fbt__media { width: 100%; }
                  #shopify-section-{{ section.id }} .fbt__media img, #shopify-section-{{ section.id }} .fbt__media svg { width: 100%; max-width: 9rem; aspect-ratio: 1 / 1; object-fit: contain; margin: 0 auto; display: block; }
                  #shopify-section-{{ section.id }} .fbt__name { font-size: 1.3rem; line-height: 1.3; color: var(--tf-vanilla-dark,#40738d); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
                  #shopify-section-{{ section.id }} .fbt__thisitem { color: var(--tf-navy,#0a1a4f); font-weight: 600; }
                  #shopify-section-{{ section.id }} .fbt__price { font-weight: 600; color: var(--tf-navy,#0a1a4f); font-size: 1.4rem; }
                  #shopify-section-{{ section.id }} .fbt__soldout { color: #b00020; font-weight: 400; font-size: 1.1rem; }
                  #shopify-section-{{ section.id }} .fbt__plus { flex: 0 0 auto; font-size: 2rem; line-height: 1; color: var(--tf-vanilla-dark,#40738d); }
                  #shopify-section-{{ section.id }} .fbt__footer { margin-top: 1.6rem; display: flex; flex-direction: column; gap: 1rem; }
                  #shopify-section-{{ section.id }} .fbt__total { font-size: {{ block.settings.fbt_total_size }}px; color: {{ block.settings.fbt_total_color }}; font-weight: 600; }
                  #shopify-section-{{ section.id }} .fbt__add { width: 100%; min-height: 4.8rem; padding: 0 2rem; border: 0; cursor: pointer; background: {{ block.settings.fbt_button_bg }}; color: {{ block.settings.fbt_button_text }}; border-radius: {{ block.settings.fbt_button_radius }}px; font-size: 1.4rem; font-weight: 500; letter-spacing: 0.04em; }
                  #shopify-section-{{ section.id }} .fbt__add[disabled] { opacity: 0.5; cursor: not-allowed; }
                  #shopify-section-{{ section.id }} .fbt__add.loading { opacity: 0.7; }
                  @media screen and (max-width: 749px) {
                    #shopify-section-{{ section.id }} .fbt__row { gap: 0.5rem; }
                    #shopify-section-{{ section.id }} .fbt__card { padding: 1.2rem 0.4rem 0.8rem; }
                    #shopify-section-{{ section.id }} .fbt__check { top: 0.4rem; left: 0.4rem; }
                    #shopify-section-{{ section.id }} .fbt__name { font-size: 1.1rem; }
                    #shopify-section-{{ section.id }} .fbt__plus { font-size: 1.6rem; }
                  }
                {%- endstyle -%}
                <frequently-bought-together class="fbt" {{ block.shopify_attributes }} data-money-format="{{ shop.money_format | escape }}">
                  {%- if block.settings.heading != blank -%}<h3 class="fbt__heading">{{ block.settings.heading }}</h3>{%- endif -%}
                  <div class="fbt__row">
                    {%- for h in fbt_list -%}
                      {%- assign p = all_products[h] -%}
                      {%- if p == blank -%}{%- continue -%}{%- endif -%}
                      {%- assign is_current = forloop.first -%}
                      {%- unless is_current -%}{%- unless p.available -%}{%- continue -%}{%- endunless -%}{%- endunless -%}
                      {%- if fbt_rendered > 0 -%}<span class="fbt__plus" aria-hidden="true">+</span>{%- endif -%}
                      {%- assign vid = p.selected_or_first_available_variant.id -%}
                      <label class="fbt__card{% if is_current %} fbt__card--current{% endif %}">
                        <input type="checkbox" class="fbt__check" data-fbt-item data-variant-id="{{ vid }}" data-price="{{ p.price }}"{% if p.available %} checked{% else %} disabled{% endif %} aria-label="{% if is_current %}This item: {% endif %}{{ p.title | escape }}">
                        <span class="fbt__media">
                          {%- if p.featured_image != blank -%}
                            <img src="{{ p.featured_image | image_url: width: 240 }}" alt="{{ p.title | escape }}" width="120" height="120" loading="lazy">
                          {%- else -%}
                            {{ 'product-1' | placeholder_svg_tag }}
                          {%- endif -%}
                        </span>
                        <span class="fbt__name">{% if is_current %}<span class="fbt__thisitem">This item:</span> {% endif %}{{ p.title }}</span>
                        <span class="fbt__price">{{ p.price | money }}{% unless p.available %} <span class="fbt__soldout">{{ 'products.product.sold_out' | t }}</span>{% endunless %}</span>
                      </label>
                      {%- assign fbt_rendered = fbt_rendered | plus: 1 -%}
                      {%- if p.available -%}
                        {%- assign fbt_total = fbt_total | plus: p.price -%}
                        {%- assign fbt_checked = fbt_checked | plus: 1 -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  <div class="fbt__footer">
                    <div class="fbt__total">Total: <span data-fbt-total>{{ fbt_total | money }}</span></div>
                    <button type="button" class="fbt__add" data-fbt-add{% if fbt_checked == 0 %} disabled{% endif %}>
                      {{ 'products.product.add_to_cart' | t }} (<span data-fbt-count>{{ fbt_checked }}</span>)
                    </button>
                  </div>
                </frequently-bought-together>
                <script>
                  (function () {
                    if (window.customElements && customElements.get('frequently-bought-together')) return;
                    class FrequentlyBoughtTogether extends HTMLElement {
                      connectedCallback() {
                        if (this._init) return;
                        this._init = true;
                        this.checks = Array.from(this.querySelectorAll('[data-fbt-item]'));
                        this.totalEl = this.querySelector('[data-fbt-total]');
                        this.countEl = this.querySelector('[data-fbt-count]');
                        this.btn = this.querySelector('[data-fbt-add]');
                        this.moneyFormat = this.dataset.moneyFormat || '';
                        var self = this;
                        this.checks.forEach(function (c) { c.addEventListener('change', self.update.bind(self)); });
                        if (this.btn) this.btn.addEventListener('click', this.addToCart.bind(this));
                        this.update();
                      }
                      update() {
                        var cents = 0, n = 0;
                        this.checks.forEach(function (c) { if (c.checked && !c.disabled) { cents += parseInt(c.dataset.price, 10) || 0; n++; } });
                        if (this.totalEl) this.totalEl.innerHTML = this.formatMoney(cents);
                        if (this.countEl) this.countEl.textContent = n;
                        if (this.btn) this.btn.disabled = n === 0;
                      }
                      addToCart() {
                        var items = [];
                        this.checks.forEach(function (c) { if (c.checked && !c.disabled) items.push({ id: parseInt(c.dataset.variantId, 10), quantity: 1 }); });
                        if (!items.length) return;
                        var cart = document.querySelector('cart-drawer') || document.querySelector('cart-notification');
                        var sections = cart && cart.getSectionsToRender ? cart.getSectionsToRender().map(function (s) { return s.id; }) : [];
                        var btn = this.btn;
                        btn.classList.add('loading');
                        btn.setAttribute('aria-busy', 'true');
                        fetch(window.routes.cart_add_url, {
                          method: 'POST',
                          headers: { 'Content-Type': 'application/json', 'Accept': 'application/javascript' },
                          body: JSON.stringify({ items: items, sections: sections, sections_url: window.location.pathname })
                        }).then(function (r) { return r.json(); }).then(function (resp) {
                          btn.classList.remove('loading');
                          btn.removeAttribute('aria-busy');
                          if (resp.status) { console.warn('FBT add error:', resp.description || resp.message); return; }
                          if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
                            publish(PUB_SUB_EVENTS.cartUpdate, { source: 'frequently-bought-together', cartData: resp });
                          }
                          if (cart && cart.renderContents) { cart.renderContents(resp); }
                          else { window.location = window.routes.cart_url; }
                        }).catch(function (e) {
                          btn.classList.remove('loading');
                          btn.removeAttribute('aria-busy');
                          console.error(e);
                        });
                      }
                      formatMoney(cents) {
                        var format = this.moneyFormat;
                        if (!format) { return '$' + (cents / 100).toFixed(2); }
                        function fwd(number, precision, thousands, decimal) {
                          precision = precision == null ? 2 : precision;
                          thousands = thousands == null ? ',' : thousands;
                          decimal = decimal == null ? '.' : decimal;
                          if (isNaN(number) || number == null) return '0';
                          number = (number / 100).toFixed(precision);
                          var parts = number.split('.');
                          var dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
                          var c = parts[1] ? decimal + parts[1] : '';
                          return dollars + c;
                        }
                        var re = /\{\{\s*(\w+)\s*\}\}/;
                        var m = format.match(re);
                        var t = m ? m[1] : 'amount';
                        var val;
                        switch (t) {
                          case 'amount_no_decimals': val = fwd(cents, 0); break;
                          case 'amount_with_comma_separator': val = fwd(cents, 2, '.', ','); break;
                          case 'amount_no_decimals_with_comma_separator': val = fwd(cents, 0, '.', ','); break;
                          default: val = fwd(cents, 2);
                        }
                        return format.replace(re, val);
                      }
                    }
                    customElements.define('frequently-bought-together', FrequentlyBoughtTogether);
                  })();
                </script>
              {%- elsif request.design_mode -%}
                <p class="fbt__notice">Frequently Bought Together: set companion product 1 and/or 2 in this block's settings.</p>
              {%- endif -%}

            {%- when 'gift_tracker' -%}
              {%- comment -%} DISPLAY-ONLY progress bar. Thresholds are entered manually in the
                editor and MUST be kept in sync with the real Monk promotion settings. This bar
                does NOT grant rewards, verify anything, or integrate with Monk - it only reads
                the live cart total (cart.total_price + the cartUpdate event) and shows progress. {%- endcomment -%}
              {%- liquid
                assign gt_milestones = section.blocks | where: 'type', 'milestone'
                assign gt_max = 0
                for m in gt_milestones
                  if m.settings.amount > gt_max
                    assign gt_max = m.settings.amount
                  endif
                endfor
                assign gt_max_cents = gt_max | times: 100
              -%}
              {%- if gt_milestones.size > 0 and gt_max_cents > 0 -%}
                {%- liquid
                  assign gt_fill = cart.total_price | times: 100 | divided_by: gt_max_cents
                  if gt_fill > 100
                    assign gt_fill = 100
                  endif
                -%}
                {%- style -%}
                  #shopify-section-{{ section.id }} .gt { display: block; margin-top: 2.4rem; }
                  #shopify-section-{{ section.id }} .gt__title { margin: 0 0 0.4rem; font-weight: 600; color: {{ block.settings.message_color }}; font-size: 1.4rem; }
                  #shopify-section-{{ section.id }} .gt__message { margin: 0 0 1.2rem; color: {{ block.settings.message_color }}; font-size: 1.3rem; line-height: 1.4; min-height: 1.4em; }
                  #shopify-section-{{ section.id }} .gt__bar { position: relative; padding-top: 3.4rem; }
                  #shopify-section-{{ section.id }} .gt__track { position: relative; height: {{ block.settings.bar_height }}px; background: {{ block.settings.track_color }}; border-radius: 999px; overflow: hidden; }
                  #shopify-section-{{ section.id }} .gt__fill { height: 100%; background: {{ block.settings.fill_color }}; border-radius: 999px; transition: width 0.4s ease; }
                  #shopify-section-{{ section.id }} .gt__point { position: absolute; bottom: 0; height: {{ block.settings.bar_height }}px; }
                  #shopify-section-{{ section.id }} .gt__tick { position: absolute; bottom: 0; left: 0; transform: translateX(-50%); width: 0.2rem; height: 100%; background: {{ block.settings.track_color }}; }
                  #shopify-section-{{ section.id }} .gt__point.is-active .gt__tick { background: {{ block.settings.marker_color }}; }
                  #shopify-section-{{ section.id }} .gt__badge { position: absolute; bottom: calc(100% + 0.8rem); left: 0; transform: translateX(-50%); white-space: nowrap; font-size: 1rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; padding: 0.3rem 0.7rem; border-radius: 0.4rem; background: #e2e5ec; color: #8590ab; transition: background 0.2s ease, color 0.2s ease; }
                  #shopify-section-{{ section.id }} .gt__point.is-active .gt__badge { background: var(--badge-bg); color: var(--badge-text); }
                  #shopify-section-{{ section.id }} .gt__point--start .gt__badge { left: 0; transform: translateX(0); }
                  #shopify-section-{{ section.id }} .gt__point--end .gt__badge { left: auto; right: 0; transform: translateX(0); }
                  @media screen and (max-width: 749px) {
                    #shopify-section-{{ section.id }} .gt__badge { font-size: 0.9rem; padding: 0.2rem 0.5rem; }
                  }
                {%- endstyle -%}
                <gift-tracker
                  class="gt"
                  {{ block.shopify_attributes }}
                  data-money-format="{{ shop.money_format | escape }}"
                  data-cart-total="{{ cart.total_price }}"
                  data-max="{{ gt_max_cents }}"
                  data-msg-away="{{ block.settings.message_away | escape }}"
                  data-msg-unlocked="{{ block.settings.message_unlocked | escape }}"
                  data-msg-all="{{ block.settings.message_all_unlocked | escape }}"
                >
                  {%- if block.settings.title != blank -%}<p class="gt__title">{{ block.settings.title }}</p>{%- endif -%}
                  <p class="gt__message" data-gt-message></p>
                  <div class="gt__bar">
                    <div class="gt__track"><div class="gt__fill" data-gt-fill style="width: {{ gt_fill }}%;"></div></div>
                    {%- for m in gt_milestones -%}
                      {%- liquid
                        assign m_cents = m.settings.amount | times: 100
                        assign m_pct = m_cents | times: 100 | divided_by: gt_max_cents
                        assign m_anchor = 'mid'
                        if m_pct <= 12
                          assign m_anchor = 'start'
                        elsif m_pct >= 88
                          assign m_anchor = 'end'
                        endif
                      -%}
                      <div class="gt__point gt__point--{{ m_anchor }}" data-gt-milestone data-amount="{{ m_cents }}" data-reward="{{ m.settings.reward_name | escape }}" style="left: {{ m_pct }}%;">
                        <span class="gt__badge" style="--badge-bg: {{ m.settings.badge_bg }}; --badge-text: {{ m.settings.badge_text_color }};">{{ m.settings.badge_text }}</span>
                        <span class="gt__tick"></span>
                      </div>
                    {%- endfor -%}
                  </div>
                </gift-tracker>
                <script>
                  (function () {
                    if (window.customElements && customElements.get('gift-tracker')) return;
                    class GiftTracker extends HTMLElement {
                      connectedCallback() {
                        if (this._init) return;
                        this._init = true;
                        this.fillEl = this.querySelector('[data-gt-fill]');
                        this.msgEl = this.querySelector('[data-gt-message]');
                        this.points = Array.from(this.querySelectorAll('[data-gt-milestone]'));
                        this.max = parseInt(this.dataset.max, 10) || 0;
                        this.moneyFormat = this.dataset.moneyFormat || '';
                        this.tplAway = this.dataset.msgAway || '';
                        this.tplUnlocked = this.dataset.msgUnlocked || '';
                        this.tplAll = this.dataset.msgAll || '';
                        this.update(parseInt(this.dataset.cartTotal, 10) || 0);
                        var self = this;
                        if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
                          this._unsub = subscribe(PUB_SUB_EVENTS.cartUpdate, function (e) { self.onCartUpdate(e); });
                        }
                      }
                      disconnectedCallback() { if (this._unsub) this._unsub(); }
                      onCartUpdate(e) {
                        if (e && e.cartData && typeof e.cartData.total_price === 'number') {
                          this.update(e.cartData.total_price);
                          return;
                        }
                        var self = this;
                        var url = (window.routes && window.routes.cart_url ? window.routes.cart_url : '/cart') + '.js';
                        fetch(url).then(function (r) { return r.json(); }).then(function (cart) {
                          if (cart && typeof cart.total_price === 'number') self.update(cart.total_price);
                        }).catch(function () {});
                      }
                      update(total) {
                        var max = this.max || 1;
                        var pct = Math.max(0, Math.min(100, (total / max) * 100));
                        if (this.fillEl) this.fillEl.style.width = pct + '%';
                        var ms = this.points.map(function (p) {
                          return { el: p, amount: parseInt(p.dataset.amount, 10) || 0, reward: p.dataset.reward || '' };
                        }).sort(function (a, b) { return a.amount - b.amount; });
                        var next = null;
                        ms.forEach(function (m) {
                          if (total >= m.amount) { m.el.classList.add('is-active'); }
                          else { m.el.classList.remove('is-active'); if (!next) next = m; }
                        });
                        var text = '';
                        if (next) {
                          text = this.tplAway.split('[amount]').join(this.formatMoney(next.amount - total)).split('[reward]').join(next.reward);
                        } else if (ms.length) {
                          text = this.tplAll || this.tplUnlocked.split('[reward]').join(ms[ms.length - 1].reward);
                        }
                        if (this.msgEl) this.msgEl.textContent = text;
                      }
                      formatMoney(cents) {
                        var format = this.moneyFormat;
                        if (!format) { return '$' + (cents / 100).toFixed(2); }
                        function fwd(number, precision, thousands, decimal) {
                          precision = precision == null ? 2 : precision; thousands = thousands == null ? ',' : thousands; decimal = decimal == null ? '.' : decimal;
                          if (isNaN(number) || number == null) return '0';
                          number = (number / 100).toFixed(precision);
                          var parts = number.split('.'); var dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands); var c = parts[1] ? decimal + parts[1] : '';
                          return dollars + c;
                        }
                        var re = /\{\{\s*(\w+)\s*\}\}/; var m = format.match(re); var t = m ? m[1] : 'amount'; var val;
                        switch (t) {
                          case 'amount_no_decimals': val = fwd(cents, 0); break;
                          case 'amount_with_comma_separator': val = fwd(cents, 2, '.', ','); break;
                          case 'amount_no_decimals_with_comma_separator': val = fwd(cents, 0, '.', ','); break;
                          default: val = fwd(cents, 2);
                        }
                        return format.replace(re, val);
                      }
                    }
                    customElements.define('gift-tracker', GiftTracker);
                  })();
                </script>
              {%- elsif request.design_mode -%}
                <p class="gt__notice">Gift Tracker: add one or more "Gift milestone" blocks (dollar amount + badge) to show the progress bar.</p>
              {%- endif -%}

            {%- when 'milestone' -%}
              {%- comment -%} Data block for the Gift Tracker bar; renders no visible element. {%- endcomment -%}
              <span class="gt-milestone-flag" {{ block.shopify_attributes }} hidden></span>

            {%- when 'rating' -%}
              {%- if product.metafields.reviews.rating.value != blank -%}
                {% liquid
                  assign rating_decimal = 0
                  assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                  if decimal >= 0.3 and decimal <= 0.7
                    assign rating_decimal = 0.5
                  elsif decimal > 0.7
                    assign rating_decimal = 1
                  endif
                %}
                <div
                  class="rating"
                  role="img"
                  aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}"
                >
                  <span
                    aria-hidden="true"
                    class="rating-star color-icon-{{ settings.accent_icons }}"
                    style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
                  ></span>
                </div>
                <p class="rating-text caption">
                  <span aria-hidden="true">
                    {{- product.metafields.reviews.rating.value }} /
                    {{ product.metafields.reviews.rating.value.scale_max -}}
                  </span>
                </p>
                <p class="rating-count caption">
                  <span aria-hidden="true">({{ product.metafields.reviews.rating_count }})</span>
                  <span class="visually-hidden">
                    {{- product.metafields.reviews.rating_count }}
                    {{ 'accessibility.total_reviews' | t -}}
                  </span>
                </p>
              {%- endif -%}
            {%- when 'complementary' -%}
              <product-recommendations
                class="complementary-products quick-add-hidden no-js-hidden{% if block.settings.make_collapsible_row %} is-accordion{% endif %}{% if block.settings.enable_quick_add %} complementary-products-contains-quick-add{% endif %}"
                data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.product_list_limit }}&intent=complementary"
              >
                {%- if recommendations.performed and recommendations.products_count > 0 -%}
                  <aside
                    aria-label="{{ 'accessibility.complementary_products' | t }}"
                    {{ block.shopify_attributes -}}
                    {% if block.settings.make_collapsible_row %}
                      class="product__accordion accordion"
                    {% endif %}
                  >
                    <div class="complementary-products__container">
                      {%- if block.settings.make_collapsible_row -%}
                        <details id="Details-{{ block.id }}-{{ section.id }}" open>
                          <summary>
                      {%- endif %}
                      <div class="summary__title">
                        {%- if block.settings.make_collapsible_row -%}
                          {% render 'icon-accordion', icon: block.settings.icon %}
                          <h2 class="h4 accordion__title">{{ block.settings.block_heading }}</h2>
                        {%- else -%}
                          <h2 class="h3 accordion__title">{{ block.settings.block_heading }}</h2>
                        {%- endif -%}
                      </div>
                      {%- if block.settings.make_collapsible_row -%}
                        {% render 'icon-caret' %}
                        </summary>
                      {%- endif -%}
                      <slideshow-component class="slider-mobile-gutter">
                        {%- assign number_of_slides = recommendations.products_count
                          | plus: 0.0
                          | divided_by: block.settings.products_per_page
                          | ceil
                        -%}
                        <div
                          id="Slider-{{ block.id }}"
                          class="grid contains-card contains-card--product complementary-slider grid--1-col slider slider--everywhere"
                          role="list"
                          {% if number_of_slides > 1 %}
                            aria-label="{{ 'general.slider.name' | t }}"
                          {% endif %}
                        >
                          {%- for i in (1..number_of_slides) -%}
                            <div
                              id="Slide-{{ block.id }}-{{ forloop.index }}"
                              class="complementary-slide complementary-slide--{{ settings.card_style }} grid__item slider__slide slideshow__slide"
                              tabindex="-1"
                              role="group"
                              {% if number_of_slides > 1 %}
                                aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
                                aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                              {% endif %}
                            >
                              <ul class="list-unstyled" role="list">
                                {%- for product in recommendations.products
                                  limit: block.settings.products_per_page
                                  offset: continue
                                -%}
                                  <li>
                                    {% render 'card-product',
                                      card_product: product,
                                      media_aspect_ratio: block.settings.image_ratio,
                                      show_secondary_image: false,
                                      lazy_load: false,
                                      show_quick_add: block.settings.enable_quick_add,
                                      section_id: section.id,
                                      horizontal_class: true,
                                      horizontal_quick_add: true
                                    %}
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </div>
                          {%- endfor -%}
                        </div>
                        {%- if number_of_slides > 1 -%}
                          <div class="slider-buttons no-js-hidden">
                            <button
                              type="button"
                              class="slider-button slider-button--prev"
                              name="previous"
                              aria-label="{{ 'general.slider.previous_slide' | t }}"
                            >
                              {% render 'icon-caret' %}
                            </button>
                            <div class="slider-counter slider-counter--{{ block.settings.pagination_style }}{% if block.settings.pagination_style == 'counter' or block.settings.pagination_style == 'numbers' %} caption{% endif %}">
                              {%- if block.settings.pagination_style == 'counter' -%}
                                <span class="slider-counter--current">1</span>
                                <span aria-hidden="true"> / </span>
                                <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                                <span class="slider-counter--total">{{ number_of_slides }}</span>
                              {%- else -%}
                                <div class="slideshow__control-wrapper">
                                  {%- for i in (1..number_of_slides) -%}
                                    <button
                                      class="slider-counter__link slider-counter__link--{{ block.settings.pagination_style }} link"
                                      aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                      aria-controls="Slider-{{ block.id }}"
                                    >
                                      {%- if block.settings.pagination_style == 'numbers' -%}
                                        {{ forloop.index -}}
                                      {%- else -%}
                                        <span class="dot"></span>
                                      {%- endif -%}
                                    </button>
                                  {%- endfor -%}
                                </div>
                              {%- endif -%}
                            </div>
                            <button
                              type="button"
                              class="slider-button slider-button--next"
                              name="next"
                              aria-label="{{ 'general.slider.next_slide' | t }}"
                            >
                              {% render 'icon-caret' %}
                            </button>
                          </div>
                        {%- endif -%}
                      </slideshow-component>
                      {%- if block.settings.make_collapsible_row -%}
                        </details>
                      {%- endif -%}
                    </div>
                  </aside>
                {%- endif -%}
                {{ 'component-card.css' | asset_url | stylesheet_tag }}
                {{ 'component-complementary-products.css' | asset_url | stylesheet_tag }}
                {%- if block.settings.enable_quick_add -%}
                  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
                  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
                {%- endif -%}
              </product-recommendations>
            {%- when 'icon-with-text' -%}
              {% render 'icon-with-text', block: block %}
          {%- endcase -%}
        {%- endfor -%}
        <a href="{{ product.url }}" class="link product__view-details animate-arrow">
          {{ 'products.product.view_full_details' | t }}
          {% render 'icon-arrow' %}
        </a>
      </product-info>
    </div>
    {%- if section.settings.media_position == 'right' -%}
      {% comment %} Duplicate gallery to display after product content on tablet/desktop breakpoint {% endcomment %}
      <div class="grid__item product__media-wrapper small-hide">
        {% render 'product-media-gallery', variant_images: variant_images, is_duplicate: true %}
      </div>
    {%- endif -%}
  </div>

  {% render 'product-media-modal', variant_images: variant_images %}

  {% assign popups = section.blocks | where: 'type', 'popup' %}
  {%- for block in popups -%}
    <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
      <div
        role="dialog"
        aria-label="{{ block.settings.text }}"
        aria-modal="true"
        class="product-popup-modal__content"
        tabindex="-1"
      >
        <button
          id="ModalClose-{{ block.id }}"
          type="button"
          class="product-popup-modal__toggle"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <div class="product-popup-modal__content-info">
          <h1 class="h2">{{ block.settings.page.title }}</h1>
          {{ block.settings.page.content }}
        </div>
      </div>
    </modal-dialog>
  {%- endfor -%}

  {%- if product.media.size > 0 -%}
    <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if first_3d_model -%}
    <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>
    <script src="{{ 'product-model.js' | asset_url }}" defer></script>
  {%- endif -%}

  <script>
    (function () {
      const productScrollRestoration = localStorage.getItem('pdpScrollRestoration');
      localStorage.removeItem('pdpScrollRestoration');
      if (productScrollRestoration && window.innerWidth < 750) {
        const [ts, scrollPosition, pathname] = productScrollRestoration.split(';');
        if (Date.now() - parseInt(ts, 10) < 1000 && pathname === window.location.pathname) {
          const scrollPositionY = parseInt(scrollPosition, 10);
          function restoreScroll() { window.scrollTo(0, scrollPositionY); }
          {% comment %} requestAnimationFrame(restoreScroll); {% endcomment %}
          document.addEventListener('DOMContentLoaded', restoreScroll);
        }
      }
    })();
    document.addEventListener('DOMContentLoaded', function () {
      function isIE() {
        const ua = window.navigator.userAgent;
        const msie = ua.indexOf('MSIE ');
        const trident = ua.indexOf('Trident/');

        return msie > 0 || trident > 0;
      }

      if (!isIE()) return;
      const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id" data-productid="{{ product.id }}"]');
      const noScriptInputWrapper = document.createElement('div');
      const variantSwitcher =
        document.querySelector('variant-radios[data-section="{{ section.id }}"]') ||
        document.querySelector('variant-selects[data-section="{{ section.id }}"]');
      noScriptInputWrapper.innerHTML = document.querySelector(
        '.product-form__noscript-wrapper-{{ section.id }}'
      ).textContent;
      variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function (event) {
        hiddenInput.value = event.currentTarget.value;
      });
    });
  </script>

  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media -%}
        "image": [
          {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
        ],
      {%- endif %}
      "description": {{ product.description | strip_html | json }},
      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
</section>

{%- liquid
  assign ps = section.settings
-%}
{%- if ps.enable_custom_styling -%}
<style>
  /* ===================================================================
     Custom Product Page Styling — scoped to this section.
     =================================================================== */

  /* ---------- 1. Section background ---------- */
  #shopify-section-{{ section.id }} {
    {%- if ps.section_gradient != blank -%}
    background-image: {{ ps.section_gradient }};
    {%- endif -%}
    background-color: {{ ps.section_bg }};
  }

  /* ---------- 2. Flavor selector swatches ---------- */
  {%- if ps.enable_flavor_styling -%}
  #shopify-section-{{ section.id }} .product-picker-list {
    display: flex;
    flex-wrap: wrap;
    gap: {{ ps.flavor_gap }}px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Each swatch item */
  #shopify-section-{{ section.id }} .product-picker-list > li,
  #shopify-section-{{ section.id }} .product-picker-item {
    flex: 0 0 auto;
    width: {{ ps.flavor_swatch_size }}px;
    text-align: center;
  }

  /* The square image area */
  #shopify-section-{{ section.id }} .product-picker-item img,
  #shopify-section-{{ section.id }} .product-picker-item .product-picker-item__image,
  #shopify-section-{{ section.id }} .product-picker-list .media {
    width: {{ ps.flavor_swatch_size }}px !important;
    height: {{ ps.flavor_swatch_size }}px !important;
    object-fit: cover !important;
    border-radius: {{ ps.flavor_image_radius }}px !important;
    border: {{ ps.flavor_border_width }}px solid {{ ps.flavor_border_color }} !important;
    background-color: {{ ps.flavor_swatch_bg }} !important;
    box-sizing: border-box;
  }

  /* Selected / active swatch */
  #shopify-section-{{ section.id }} .product-picker-item[aria-current="true"] img,
  #shopify-section-{{ section.id }} .product-picker-item.is-selected img,
  #shopify-section-{{ section.id }} .product-picker-list .active img {
    border-color: {{ ps.flavor_selected_border }} !important;
    border-width: {{ ps.flavor_selected_border_width }}px !important;
  }

  /* Caption (flavor name) */
  #shopify-section-{{ section.id }} .product-picker-item__label,
  #shopify-section-{{ section.id }} .product-picker-item figcaption,
  #shopify-section-{{ section.id }} .product-picker-item .label {
    display: block;
    margin-top: {{ ps.flavor_caption_gap }}px;
    color: {{ ps.flavor_caption_color }} !important;
    font-size: {{ ps.flavor_caption_size }}rem !important;
    font-weight: {{ ps.flavor_caption_weight }};
    line-height: 1.2;
  }

  /* Size subtext (smaller line under the caption).
     Shows if the picker snippet outputs an element with a size/subtext class. */
  #shopify-section-{{ section.id }} .product-picker-item__size,
  #shopify-section-{{ section.id }} .product-picker-item__subtext,
  #shopify-section-{{ section.id }} .product-picker-item .size {
    display: block;
    margin-top: 2px;
    color: {{ ps.flavor_size_color }} !important;
    font-size: {{ ps.flavor_size_text_size }}rem !important;
    font-weight: 400;
    line-height: 1.1;
  }
  {%- endif -%}

  /* ---------- 2b. Custom (editor-driven) flavor swatches ---------- */
  {%- if ps.enable_flavor_styling -%}
  #shopify-section-{{ section.id }} .custom-flavor-swatch-{{ section.id }} {
    display: inline-block;
    vertical-align: top;
    width: {{ ps.flavor_swatch_size }}px;
    margin-right: {{ ps.flavor_gap }}px;
    margin-bottom: {{ ps.flavor_gap }}px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .custom-flavor-swatch__link-{{ section.id }} {
    display: block;
    text-decoration: none;
  }

  /* Positioned media wrapper so the corner tag can pin to the image */
  #shopify-section-{{ section.id }} .custom-flavor-swatch__media-{{ section.id }} {
    position: relative;
    display: block;
    width: {{ ps.flavor_swatch_size }}px;
    height: {{ ps.flavor_swatch_size }}px;
    border-radius: {{ ps.flavor_image_radius }}px;
    overflow: hidden;
  }

  /* Corner ribbon tag — wraps the top-right corner diagonally */
  #shopify-section-{{ section.id }} .custom-flavor-swatch__tag-{{ section.id }} {
    display: block;
    margin-top: {{ ps.flavor_tag_offset }}px;
    background-color: {{ ps.flavor_tag_bg }};
    color: {{ ps.flavor_tag_text_color }};
    font-size: {{ ps.flavor_tag_text_size }}rem;
    font-weight: {{ ps.flavor_tag_weight }};
    line-height: 1.2;
    text-align: center;
    padding: {{ ps.flavor_tag_padding_y }}px {{ ps.flavor_tag_padding_x }}px;
    border-radius: {{ ps.flavor_tag_radius }}px;
  }

  #shopify-section-{{ section.id }} .custom-flavor-swatch__image-{{ section.id }} {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ ps.flavor_image_radius }}px;
    border: {{ ps.flavor_border_width }}px solid {{ ps.flavor_border_color }};
    background-color: {{ ps.flavor_swatch_bg }};
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .custom-flavor-swatch-{{ section.id }}.is-current .custom-flavor-swatch__image-{{ section.id }} {
    border-color: {{ ps.flavor_selected_border }};
    border-width: {{ ps.flavor_selected_border_width }}px;
  }

  #shopify-section-{{ section.id }} .custom-flavor-swatch__placeholder-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .custom-flavor-swatch__placeholder-{{ section.id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.4;
  }

  #shopify-section-{{ section.id }} .custom-flavor-swatch__caption-{{ section.id }} {
    display: block;
    margin-top: {{ ps.flavor_caption_gap }}px;
    color: {{ ps.flavor_caption_color }};
    font-size: {{ ps.flavor_caption_size }}rem;
    font-weight: {{ ps.flavor_caption_weight }};
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .custom-flavor-swatch__size-{{ section.id }} {
    display: block;
    margin-top: 2px;
    color: {{ ps.flavor_size_color }};
    font-size: {{ ps.flavor_size_text_size }}rem;
    font-weight: 400;
    line-height: 1.1;
  }
  {%- endif -%}

  /* ---------- Quantity stepper merged with Add to Cart (Magic-Spoon row) ---------- */
  #shopify-section-{{ section.id }} .tf-atc-row {
    display: flex;
    align-items: stretch;
    gap: {{ ps.qty_gap }}px;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .tf-atc-row > .tf-qty { flex: 0 0 auto; margin: 0; }
  /* Add to Cart fills the rest of the row; Shop Pay / dynamic checkout stays below */
  #shopify-section-{{ section.id }} .tf-atc-row > .product-form__submit,
  #shopify-section-{{ section.id }} .tf-atc-row > button[name="add"] {
    flex: 1 1 auto;
    min-width: 0;
    margin: 0;
  }
  #shopify-section-{{ section.id }} .tf-qty__control {
    display: inline-flex;
    align-items: center;
    height: 100%;
    width: auto;
    min-height: {{ ps.qty_min_height }}px;
    background: {{ ps.qty_bg }};
    border: {{ ps.qty_border_width }}px solid {{ ps.qty_border_color }};
    border-radius: {{ ps.qty_radius }}px;
    overflow: hidden;
  }
  /* Neutralize Dawn's default .quantity pseudo-frames (inner outline + bg box)
     so only our single tf-qty border shows — no more box-within-a-box. */
  #shopify-section-{{ section.id }} .tf-qty__control::before,
  #shopify-section-{{ section.id }} .tf-qty__control::after {
    display: none !important;
    content: none !important;
    box-shadow: none !important;
  }
  #shopify-section-{{ section.id }} .tf-qty__btn {
    width: {{ ps.qty_button_size }}px;
    min-height: {{ ps.qty_min_height }}px;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: {{ ps.qty_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .tf-qty__btn:hover { opacity: 0.65; }
  #shopify-section-{{ section.id }} .tf-qty__btn svg { width: 1.4rem; height: 1.4rem; }
  #shopify-section-{{ section.id }} .tf-qty__input {
    width: {{ ps.qty_input_width }}px;
    min-height: {{ ps.qty_min_height }}px;
    border: 0;
    background: transparent;
    text-align: center;
    color: {{ ps.qty_text_color }};
    font-size: 1.5rem;
    font-weight: 500;
    -moz-appearance: textfield;
    appearance: textfield;
  }
  #shopify-section-{{ section.id }} .tf-qty__input::-webkit-outer-spin-button,
  #shopify-section-{{ section.id }} .tf-qty__input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  /* ---------- 3. Add to cart button ---------- */
  {%- if ps.enable_button_styling -%}
  #shopify-section-{{ section.id }} .product-form__submit,
  #shopify-section-{{ section.id }} .product-form__submit.button,
  #shopify-section-{{ section.id }} button[name="add"] {
    {%- if ps.button_gradient != blank -%}
    background-image: {{ ps.button_gradient }} !important;
    {%- endif -%}
    background-color: {{ ps.button_bg }} !important;
    color: {{ ps.button_text_color }} !important;
    border-radius: {{ ps.button_radius }}px !important;
    border: {{ ps.button_border_width }}px solid {{ ps.button_border_color }} !important;
    font-size: {{ ps.button_text_size }}rem !important;
    padding: {{ ps.button_padding_y }}px {{ ps.button_padding_x }}px !important;
    min-height: 0 !important;
  }

  #shopify-section-{{ section.id }} .product-form__submit:hover,
  #shopify-section-{{ section.id }} button[name="add"]:hover {
    opacity: 0.9;
  }

  /* Button label text override */
  {%- if ps.button_label != blank -%}
  #shopify-section-{{ section.id }} .product-form__submit span,
  #shopify-section-{{ section.id }} button[name="add"] > span {
    font-size: 0;
  }
  #shopify-section-{{ section.id }} .product-form__submit span::after,
  #shopify-section-{{ section.id }} button[name="add"] > span::after {
    content: "{{ ps.button_label }}";
    font-size: {{ ps.button_text_size }}rem;
  }
  {%- endif -%}
  {%- endif -%}

  /* ---------- Navy product header (title, reviews count, description, price) ----------
     Brand decision: this key purchase info reads too light in the scheme text
     color (#40738D) on white, so force navy. Targets text only — the review
     star glyphs keep their own color. */
  #shopify-section-{{ section.id }} .product__title,
  #shopify-section-{{ section.id }} .product__title a,
  #shopify-section-{{ section.id }} .product__text,
  #shopify-section-{{ section.id }} .product__text.subtitle,
  #shopify-section-{{ section.id }} .price,
  #shopify-section-{{ section.id }} .price__container,
  #shopify-section-{{ section.id }} .price-item,
  #shopify-section-{{ section.id }} .price-item--regular,
  #shopify-section-{{ section.id }} .price-item--sale,
  #shopify-section-{{ section.id }} [data-selling-plan-price-display],
  #shopify-section-{{ section.id }} [data-compare-price],
  #shopify-section-{{ section.id }} .spr-badge-caption,
  #shopify-section-{{ section.id }} .jdgm-prev-badge__text,
  #shopify-section-{{ section.id }} .rating-text {
    color: #0A1A4F !important;
  }
</style>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.main-product.name",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "text",
      "name": "t:sections.main-product.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "Text block",
          "label": "t:sections.main-product.blocks.text.settings.text.label"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "body",
              "label": "t:sections.main-product.blocks.text.settings.text_style.options__1.label"
            },
            {
              "value": "subtitle",
              "label": "t:sections.main-product.blocks.text.settings.text_style.options__2.label"
            },
            {
              "value": "uppercase",
              "label": "t:sections.main-product.blocks.text.settings.text_style.options__3.label"
            }
          ],
          "default": "body",
          "label": "t:sections.main-product.blocks.text.settings.text_style.label"
        },
        {
          "type": "header",
          "content": "Custom text styling"
        },
        {
          "type": "range",
          "id": "custom_text_size",
          "label": "Text size",
          "info": "1.5rem is the theme default. Slide left for smaller, right for larger.",
          "min": 0.8,
          "max": 3.0,
          "step": 0.1,
          "unit": "rem",
          "default": 1.5
        },
        {
          "type": "color",
          "id": "custom_text_color",
          "label": "Text color",
          "info": "Leave blank to use the theme default."
        },
        {
          "type": "select",
          "id": "custom_text_align",
          "label": "Alignment",
          "options": [
            { "value": "", "label": "Default" },
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": ""
        },
        {
          "type": "select",
          "id": "custom_text_weight",
          "label": "Font weight",
          "options": [
            { "value": "", "label": "Default" },
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" }
          ],
          "default": ""
        }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.main-product.blocks.title.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Leave this blank to use the default product title."
        },
        {
          "type": "checkbox",
          "id": "remove_flavor_name",
          "label": "Remove flavor name from title"
        }
      ]
    },
    {
      "type": "collab_title",
      "name": "Custom Collab Title",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "number",
          "id": "image_top_margin",
          "label": "Image top margin, in pixels",
          "info": "Setting a negative value will pull the image up",
          "default": -12
        },
        {
          "type": "text",
          "id": "hidden_name",
          "label": "Collab name",
          "info": "Enter the text of the collab image, like 'x Alix Earle,' to complete the title. This text will be hidden from visitors but could benefit SEO. For example, if you set a title of 'AminoLean' and a collab name of 'x Alix Earle', it becomes 'AminoLean x Alix Earle'"
        }
      ]
    },
    {
      "type": "alix_collab_title",
      "name": "Alix Earle Collab Title",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    },
    {
      "type": "reviews_badge_price",
      "name": "Reviews badge + Price",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "badge_image",
          "label": "Alternate badge image",
          "info": "Upload an alternate image to replace the default Shopify Product Reviews badge  (e.g. to highlight Amazon reviews)"
        },
        {
          "type": "number",
          "id": "hide_if_no_reviews",
          "label": "Hide if there are no reviews"
        }
      ]
    },
    {
      "type": "price",
      "name": "t:sections.main-product.blocks.price.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_badges",
          "label": "Show badges",
          "default": false
        }
      ]
    },
    {
      "type": "sku",
      "name": "t:sections.main-product.blocks.sku.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "body",
              "label": "t:sections.main-product.blocks.sku.settings.text_style.options__1.label"
            },
            {
              "value": "subtitle",
              "label": "t:sections.main-product.blocks.sku.settings.text_style.options__2.label"
            },
            {
              "value": "uppercase",
              "label": "t:sections.main-product.blocks.sku.settings.text_style.options__3.label"
            }
          ],
          "default": "body",
          "label": "t:sections.main-product.blocks.sku.settings.text_style.label"
        }
      ]
    },
    {
      "type": "inventory",
      "name": "t:sections.main-product.blocks.inventory.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "text_style",
          "options": [
            {
              "value": "body",
              "label": "t:sections.main-product.blocks.inventory.settings.text_style.options__1.label"
            },
            {
              "value": "subtitle",
              "label": "t:sections.main-product.blocks.inventory.settings.text_style.options__2.label"
            },
            {
              "value": "uppercase",
              "label": "t:sections.main-product.blocks.inventory.settings.text_style.options__3.label"
            }
          ],
          "default": "body",
          "label": "t:sections.main-product.blocks.inventory.settings.text_style.label"
        },
        {
          "type": "range",
          "id": "inventory_threshold",
          "label": "t:sections.main-product.blocks.inventory.settings.inventory_threshold.label",
          "min": 0,
          "max": 100,
          "step": 1,
          "info": "t:sections.main-product.blocks.inventory.settings.inventory_threshold.info",
          "default": 10
        },
        {
          "type": "checkbox",
          "id": "show_inventory_quantity",
          "label": "t:sections.main-product.blocks.inventory.settings.show_inventory_quantity.label",
          "default": true
        }
      ]
    },
    {
      "type": "quantity_selector",
      "name": "t:sections.main-product.blocks.quantity_selector.name",
      "limit": 1
    },
    {
      "type": "tf_quantity",
      "name": "Quantity stepper",
      "limit": 1
    },
    {
      "type": "fbt",
      "name": "Frequently bought",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently bought together" },
        { "type": "product", "id": "companion_1", "label": "Companion product 1" },
        { "type": "product", "id": "companion_2", "label": "Companion product 2" },
        { "type": "header", "content": "Styling" },
        { "type": "color", "id": "fbt_card_bg", "label": "Card background", "default": "#FFFFFF" },
        { "type": "color", "id": "fbt_card_border", "label": "Card border", "default": "#E2E5EC" },
        { "type": "range", "id": "fbt_card_radius", "label": "Card corner radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 12 },
        { "type": "color", "id": "fbt_check_color", "label": "Checkbox color", "default": "#0A1A4F" },
        { "type": "color", "id": "fbt_total_color", "label": "Total text color", "default": "#0A1A4F" },
        { "type": "range", "id": "fbt_total_size", "label": "Total text size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 18 },
        { "type": "color", "id": "fbt_button_bg", "label": "Button background", "default": "#0A1A4F" },
        { "type": "color", "id": "fbt_button_text", "label": "Button text color", "default": "#FFFFFF" },
        { "type": "range", "id": "fbt_button_radius", "label": "Button corner radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 8 }
      ]
    },
    {
      "type": "gift_tracker",
      "name": "Gift tracker",
      "limit": 1,
      "settings": [
        { "type": "paragraph", "content": "Display-only progress bar. Enter thresholds manually and keep them in sync with your Monk promotion settings - it shows progress, it does not grant rewards or integrate with Monk." },
        { "type": "text", "id": "title", "label": "Title (optional)" },
        { "type": "text", "id": "message_away", "label": "Message - away", "info": "Use [amount] for the remaining total and [reward] for the reward name.", "default": "You're [amount] away from [reward]!" },
        { "type": "text", "id": "message_unlocked", "label": "Message - unlocked", "info": "Use [reward].", "default": "You've unlocked [reward]!" },
        { "type": "text", "id": "message_all_unlocked", "label": "Message - all unlocked", "default": "You've unlocked everything!" },
        { "type": "header", "content": "Bar styling" },
        { "type": "color", "id": "fill_color", "label": "Fill color", "default": "#0A1A4F" },
        { "type": "color", "id": "track_color", "label": "Track color", "default": "#E2E5EC" },
        { "type": "range", "id": "bar_height", "min": 4, "max": 20, "step": 1, "unit": "px", "label": "Bar height", "default": 8 },
        { "type": "color", "id": "marker_color", "label": "Marker color", "default": "#0A1A4F" },
        { "type": "color", "id": "message_color", "label": "Message text color", "default": "#40738D" }
      ]
    },
    {
      "type": "milestone",
      "name": "Gift milestone",
      "settings": [
        { "type": "number", "id": "amount", "label": "Dollar amount", "default": 30 },
        { "type": "text", "id": "badge_text", "label": "Badge text", "default": "SHIPS FREE" },
        { "type": "text", "id": "reward_name", "label": "Reward name (for message)", "default": "free shipping" },
        { "type": "color", "id": "badge_bg", "label": "Badge background", "default": "#0A1A4F" },
        { "type": "color", "id": "badge_text_color", "label": "Badge text color", "default": "#FFFFFF" }
      ]
    },
    {
      "type": "flavor_picker",
      "name": "Flavor Picker",
      "limit": 1,
      "settings": [
        {
          "type": "product_list",
          "id": "product_list",
          "label": "Products"
        },
        {
          "type": "checkbox",
          "id": "horizontal_layout",
          "label": "Horizontal layout",
          "default": true
        }
      ]
    },
    {
      "type": "product_picker_list",
      "name": "Product Picker List",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "horizontal_layout",
          "label": "Horizontal layout",
          "default": true
        }
      ]
    },
    {
      "type": "product_picker_product",
      "name": "Product-picker product",
      "settings": [
        {
