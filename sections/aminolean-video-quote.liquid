{%- liquid
  assign section_video = section.settings.video
  if section_video == blank
    assign section_video = section.settings.fallback_video
  endif
-%}

{%- if section_video != blank -%}
  {{ 'video-section.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {%- liquid
    assign video_id = section_video.id
    assign video_alt = section_video.alt | default: section.settings.description
    assign alt = 'sections.video.load_video' | t: description: video_alt | escape
    assign poster = section_video.preview_image | default: section.settings.cover_image
    if section.settings.heading == blank and section.settings.signature_image == blank
      assign video_only = true
    endif

    if section_video != null
      assign ratio_diff = section_video.aspect_ratio | minus: poster.aspect_ratio | abs
      if ratio_diff < 0.01 and ratio_diff > 0
        assign fix_ratio = true
      endif
    endif
  -%}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  {%- capture sizes -%}100vw{%- endcapture -%}

  <div class="color-{{ section.settings.color_scheme }}">
    <div class="video-section video-section--row isolate{% if video_only %} video-section--video-only{% endif %}">
      {%- unless section.settings.heading == blank and section.settings.signature_image == blank -%}
        <div
          class="video-section__quote-wrapper page-width section-{{ section.id }}-padding"
        >
          {%- unless section.settings.heading == blank -%}
            <div class="title-wrapper title-wrapper--no-top-margin">
              <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
            </div>
          {%- endunless -%}

          {%- if section.settings.signature_image != blank -%}
            <div class="signature__wrapper">
              {{
                section.settings.signature_image
                | image_url: width: section.settings.signature_image.width
                | image_tag:
                  width: section.settings.signature_image.width,
                  height: section.settings.signature_image.height,
                  loading: 'lazy'
              }}
            </div>
          {%- endif -%}
        </div>
      {%- endunless -%}
      <div class="video-section__media-wrapper">
        <noscript>
          <div
            class="video-section__media"
            {% if poster != null %}
              style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
            {% endif %}
          >
            {%- if section_video != null -%}
              {{
                section_video
                | video_tag:
                  image_size: '1100x',
                  loop: section.settings.enable_video_looping,
                  controls: true,
                  muted: section.settings.mute_video
              }}
            {%- endif -%}
          </div>
        </noscript>
        <deferred-media
          class="video-section__media deferred-media no-js-hidden gradient global-media-settings global-media-settings--full-width media-fit-cover"
          data-media-id="{{ video_id }}"
          data-focus-on-click="false"
          {% if poster != null %}
            style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
          {% endif %}
        >
          <button
            id="Deferred-Poster-Modal-{{ video_id }}"
            class="video-section__poster media deferred-media__poster media--landscape"
            type="button"
            aria-label="{{ alt }}"
          >
            {%- if poster != null -%}
              {{
                poster
                | image_url: width: 3840
                | image_tag:
                  loading: 'lazy',
                  sizes: sizes,
                  widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                  alt: alt
              }}
            {%- endif -%}
            <span class="deferred-media__poster-button deferred-media__poster-button--play motion-reduce">
              {%- render 'dawn-icon-play' -%}
            </span>
          </button>
          <template>
            {%- if section_video != null -%}
              {{
                section_video
                | video_tag:
                  image_size: '1100x',
                  autoplay: true,
                  loop: section.settings.enable_video_looping,
                  controls: true,
                  muted: section.settings.mute_video
              }}
            {%- endif -%}
          </template>
        </deferred-media>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "AminoLean: Video + Quote",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Video",
      "label": "Quote heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "image_picker",
      "id": "signature_image",
      "label": "Signature image"
    },
    {
      "type": "checkbox",
      "id": "mute_video",
      "label": "Mute video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "t:sections.video.settings.enable_video_looping.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__1.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video.settings.video.label"
    },
    {
      "type": "video",
      "id": "fallback_video",
      "label": "Fallback video",
      "info": "You can use this to set a fallback video for all products on this template. Then, if you link the above \"Video\" field to a product metafield, a PDP without a video will default to this video instead."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.video.settings.cover_image.label"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.video.settings.description.label",
      "info": "t:sections.video.settings.description.info"
    },
    {
      "type": "header",
      "content": "t:sections.video.settings.header__3.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "accent-inverse"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "AminoLean: Video + Quote"
    }
  ]
}
{% endschema %}
