{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- if section.settings.background_color.alpha > 0 -%}
    .section-{{ section.id }}-container {
      background-color: {{ section.settings.background_color }};
    }
  {%- endif -%}
{%- endstyle -%}
{%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
  {%- assign has_button = true -%}
{%- endif -%}

<div
  id="StoreLogos-{{ section.id }}"
  class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}"
>
  <div class="page-width tw-flex tw-flex-col tw-items-center tablet:tw-grid tablet:tw-grid-cols-12 tablet:tw-gap-32">
    <div class="tw-col-start-1 tw-col-end-7 tw-max-w-sm tw-text-center desktop:tw-col-start-2 tablet:tw-justify-self-center tablet:tw-pr-32">
      <h2 class="color-foreground-accent-1 rte inline-richtext tw-mb-24">
        {{ section.settings.heading | replace: 'p>', 'span>' }}
      </h2>

      {%- if has_button -%}
        <a
          class="tw-mt-24 button tw-hidden tablet:tw-flex tablet:tw-min-w-0 tw-max-w-xs tw-mx-auto"
          href="{{ section.settings.button_link }}"
        >
          {{- section.settings.button_label -}}
        </a>
      {%- endif -%}
    </div>

    <div class="aminolean-store-logos__logos-wrapper tw-items-start tw-col-span-6 tw-space-y-18 tablet:tw-space-y-24">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          {{ block.settings.image | image_url: width: section.settings.logo_max_width | image_tag: loading: 'lazy' }}
        </div>
      {%- endfor -%}
    </div>

    {%- if has_button -%}
      <a class="button tablet:tw-hidden tw-max-w-sm tw-mt-24" href="{{ section.settings.button_link }}">
        {{- section.settings.button_label -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "AminoLean: Store Logos",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "id": "heading",
      "type": "richtext",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Find Near You"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "number",
      "id": "logo_max_width",
      "label": "Maximum logo width (px)",
      "default": 220
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AminoLean: Store Logos"
    }
  ]
}
{% endschema %}
